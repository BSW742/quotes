  .slide-caption-input:focus { outline: none; border-color: var(--cyan); }
  .theme-light .slide-caption-input { border-color: rgba(0,0,0,0.1); }
  .theme-light .slide-image-placeholder { color: rgba(0,0,0,0.3); }
  .slide-headline-input {
    width: 100%; background: transparent; border: none; border-bottom: 2px dashed rgba(255,255,255,0.3);
    color: inherit; font-size: 2rem; font-weight: 700; text-align: center;
