  function addBlock(type: Block['type']) {
    if (!currentQuote) return;
    const id = genId();
    let block: Block;

    switch (type) {
      case 'hero':
        block = { id, type: 'hero', title: 'Your Title', subtitle: 'Subtitle here' };
        break;
      case 'section':
        block = { id, type: 'section', title: 'Section Title', content: 'Your content here...' };
        break;
      case 'pricing':
        block = { id, type: 'pricing', title: 'Investment', showTotal: true, items: [
          { id: genId(), name: 'Item', description: 'Description', quantity: 1, unitPrice: 0, optional: false, selected: true }
        ]};
        break;
      case 'divider':
        block = { id, type: 'divider' };
        break;
      case 'accept':
        block = { id, type: 'accept', buttonText: 'Accept Proposal', terms: 'By accepting, you agree to the terms.' };
        break;
      case 'split':
        block = { id, type: 'split', title: 'Section Title', content: 'Add your content here...', imageUrl: '' };
        break;
      default:
        return;
    }

    currentQuote.blocks.push(block);
    render();
  }

  function removeBlock(id: string) {
    if (!currentQuote) return;
    currentQuote.blocks = currentQuote.blocks.filter(b => b.id !== id);
    render();
  }

  function moveBlock(id: string, dir: -1 | 1) {
    if (!currentQuote) return;
    const idx = currentQuote.blocks.findIndex(b => b.id === id);
    if (idx < 0) return;
    const newIdx = idx + dir;
    if (newIdx < 0 || newIdx >= currentQuote.blocks.length) return;
    const blocks = [...currentQuote.blocks];
    [blocks[idx], blocks[newIdx]] = [blocks[newIdx], blocks[idx]];
    currentQuote.blocks = blocks;
    render();
  }

  function editPricing(blockId: string) {
    if (!currentQuote) return;
    const block = currentQuote.blocks.find(b => b.id === blockId) as PricingBlock | undefined;
    if (block) {
      editingPricingBlock = JSON.parse(JSON.stringify(block));
      modalType = 'pricing';
      showModal = true;
      render();
    }
  }

  function savePricingEdit() {
    if (!currentQuote || !editingPricingBlock) return;
    const idx = currentQuote.blocks.findIndex(b => b.id === editingPricingBlock!.id);
    if (idx >= 0) {
      currentQuote.blocks[idx] = editingPricingBlock;
    }
    showModal = false;
    editingPricingBlock = null;
    render();
  }

  function render() {
    const app = document.getElementById('app');
    if (!app) return;

    app.innerHTML = `
      <div class="app-layout">
        <nav class="sidebar">
          <img src="https://bridgepoint.co.nz/logos/Bridge-Point_white.png" alt="Bridge Point" class="logo">
          <button class="nav-item ${view === 'dashboard' ? 'active' : ''}" data-view="dashboard">${icons.quotes}<span>Quotes</span>${quotes.length > 0 ? `<span class="nav-badge">${quotes.length}</span>` : ''}</button>
          <button class="nav-item ${view === 'templates' ? 'active' : ''}" data-view="templates">${icons.templates}<span>Templates</span></button>
          <button class="nav-item ${view === 'slides' || view === 'slides-editor' || view === 'slides-view' ? 'active' : ''}" data-view="slides">${icons.slides}<span>Slides</span>${slideshows.length > 0 ? `<span class="nav-badge">${slideshows.length}</span>` : ''}</button>
          <button class="nav-item ${view === 'assets' ? 'active' : ''}" data-view="assets">${icons.assets}<span>Assets</span>${assets.length > 0 ? `<span class="nav-badge">${assets.length}</span>` : ''}</button>
          <button class="sync-status synced" data-action="force-sync" title="Click to re-sync from cloud">✓ Synced to cloud</button>
        </nav>
        <main class="main-content">
          ${view === 'dashboard' ? renderDashboard() : ''}
          ${view === 'templates' ? renderTemplates() : ''}
          ${view === 'editor' ? renderEditor() : ''}
          ${view === 'slides' ? renderSlidesList() : ''}
          ${view === 'slides-editor' ? renderSlidesEditor() : ''}
          ${view === 'slides-view' ? renderSlidesView() : ''}
          ${view === 'assets' ? renderAssets() : ''}
        </main>
      </div>
      ${showModal ? renderModal() : ''}
      ${toastMessage ? `<div class="toast">${toastMessage}</div>` : ''}
      ${processingAssets ? `
        <div class="processing-overlay">
          <div class="processing-modal">
            <div class="processing-spinner"></div>
            <h3>Processing ${processingAssetsCount} file${processingAssetsCount !== 1 ? 's' : ''}...</h3>
            <p>Creating thumbnails</p>
          </div>
        </div>
      ` : ''}
    `;
    attachListeners();
  }

  function renderDashboard(): string {
    if (loading) return '<div class="empty-state"><p>Loading...</p></div>';

    if (quotes.length === 0) {
      return `
        <div class="page-header"><h1 class="page-title">Quotes</h1></div>
        <div class="empty-state">
          <div class="empty-icon">${icons.quotes}</div>
          <h2 class="empty-title">No quotes yet</h2>
          <p class="empty-desc">Create your first proposal to get started</p>
          <button class="btn btn-primary" data-action="new-quote">${icons.plus} New Quote</button>
        </div>
      `;
    }

    return `
      <div class="page-header">
        <h1 class="page-title">Quotes</h1>
        <button class="btn btn-primary" data-action="new-quote">${icons.plus} New Quote</button>
      </div>
      <table class="quotes-table">
        <thead><tr><th>Quote</th><th>Status</th><th>Amount</th><th>Created</th><th>Views</th><th></th></tr></thead>
        <tbody>
          ${quotes.map(q => `
            <tr data-edit-quote="${q.id}">
              <td><div class="quote-title">${q.title}</div><div class="quote-client">${q.clientName || 'No client'}</div></td>
              <td><span class="status-badge status-${q.status}">${q.status}</span></td>
              <td class="quote-amount">${formatCurrency(q.total, q.currency)}</td>
              <td>${formatDate(q.createdAt)}</td>
              <td>${q.viewCount}</td>
              <td><div class="quote-actions" onclick="event.stopPropagation()">
                <button class="btn btn-ghost btn-sm" data-action="pdf" data-id="${q.id}" title="Download PDF">${icons.pdf}</button>
                <button class="btn btn-ghost btn-sm" data-action="edit" data-id="${q.id}">${icons.edit}</button>
                <button class="btn btn-ghost btn-sm" data-action="send" data-id="${q.id}">${icons.send}</button>
                <button class="btn btn-ghost btn-sm" data-action="delete" data-id="${q.id}">${icons.trash}</button>
              </div></td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    `;
  }

  function renderTemplates(): string {
    return `
      <div class="page-header"><h1 class="page-title">Templates</h1></div>
      <div class="templates-grid">
        ${templates.map((t, i) => `
          <div class="template-card" data-template="${t.id}">
            <div class="template-preview gradient-${(i % 3) + 1}">
              <h3>${t.name}</h3>
              <p>${t.description}</p>
            </div>
            <div class="template-info">
              <div class="template-name">${t.name}</div>
              <div class="template-desc">${t.category}</div>
            </div>
          </div>
        `).join('')}
      </div>
    `;
  }

  function renderEditor(): string {
    if (!currentQuote) return '';

    return `
      <div class="page-header">
        <button class="btn btn-ghost" data-action="back">← Back</button>
        <div style="display:flex;gap:12px;align-items:center">
          <button class="btn btn-secondary btn-sm" data-action="delete-quote" style="color:#ff4444;border-color:#ff4444" title="Delete quote">${icons.x} Delete</button>
          <button class="btn btn-secondary" data-action="duplicate">${icons.copy} Duplicate</button>
          <button class="btn btn-secondary" data-action="preview">${icons.eye} Preview</button>
          <button class="btn btn-secondary" data-action="pdf">${icons.pdf} PDF</button>
          <button class="btn btn-secondary" data-action="copy-link">${icons.link} Copy Link</button>
          <button class="btn btn-success" data-action="send-modal">${icons.send} Send</button>
          <button class="btn btn-primary" data-action="save" ${saving ? 'disabled' : ''}>${saving ? 'Saving...' : `${icons.check} Save`}</button>
        </div>
      </div>
      <div class="editor-layout">
        <div class="editor-sidebar">
          <div class="editor-panel">
            <div class="panel-title">Quote Details</div>
            <div class="form-group">
              <label class="form-label">Title</label>
              <input class="form-input" type="text" id="quote-title" value="${currentQuote.title}" placeholder="Quote title">
            </div>
            <div class="form-group">
              <label class="form-label">Client Name</label>
              <input class="form-input" type="text" id="quote-client" value="${currentQuote.clientName}" placeholder="Client name">
            </div>
            <div class="form-group">
              <label class="form-label">Client Email</label>
              <input class="form-input" type="email" id="quote-email" value="${currentQuote.clientEmail}" placeholder="client@example.com">
            </div>
            <div class="form-group">
              <label class="form-label">Client Website</label>
              <input class="form-input" type="url" id="quote-website" value="${currentQuote.clientWebsite || ''}" placeholder="https://example.com">
            </div>
            <div class="form-group">
              <label class="form-label">Client Logo</label>
              <div style="display:flex;gap:8px;align-items:center">
                <input class="form-input" type="file" id="quote-logo-upload" accept="image/*" style="flex:1">
              </div>
              ${currentQuote.clientLogo ? `<img src="${currentQuote.clientLogo}" style="max-height:40px;margin-top:8px;border-radius:4px">` : ''}
            </div>
            <div class="form-group">
              <label class="form-label">Hero Theme</label>
              <div class="theme-swatches">
                <div class="theme-swatch gradient ${currentQuote.heroTheme === 'gradient' || !currentQuote.heroTheme ? 'active' : ''}" data-theme="gradient" title="Gradient"></div>
                <div class="theme-swatch cyan ${currentQuote.heroTheme === 'cyan' ? 'active' : ''}" data-theme="cyan" title="Cyan"></div>
                <div class="theme-swatch purple ${currentQuote.heroTheme === 'purple' ? 'active' : ''}" data-theme="purple" title="Purple"></div>
                <div class="theme-swatch blue ${currentQuote.heroTheme === 'blue' ? 'active' : ''}" data-theme="blue" title="Blue"></div>
                <div class="theme-swatch dark ${currentQuote.heroTheme === 'dark' ? 'active' : ''}" data-theme="dark" title="Dark"></div>
                <div class="theme-swatch light ${currentQuote.heroTheme === 'light' ? 'active' : ''}" data-theme="light" title="Light"></div>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Status</label>
              <select class="form-input" id="quote-status">
                <option value="draft" ${currentQuote.status === 'draft' ? 'selected' : ''}>Draft</option>
                <option value="sent" ${currentQuote.status === 'sent' ? 'selected' : ''}>Sent</option>
                <option value="viewed" ${currentQuote.status === 'viewed' ? 'selected' : ''}>Viewed</option>
                <option value="accepted" ${currentQuote.status === 'accepted' ? 'selected' : ''}>Accepted</option>
                <option value="declined" ${currentQuote.status === 'declined' ? 'selected' : ''}>Declined</option>
              </select>
            </div>
            <div class="form-group">
              <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                <input type="checkbox" id="quote-show-header" ${currentQuote.showHeader !== false ? 'checked' : ''}>
                <span class="form-label" style="margin:0">Show header (logo & tagline)</span>
              </label>
            </div>
            <div class="form-group">
              <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                <input type="checkbox" id="quote-logo-background" ${currentQuote.logoNeedsBackground ? 'checked' : ''}>
                <span class="form-label" style="margin:0">Logo needs white background</span>
              </label>
            </div>
          </div>
          <div class="editor-panel">
            <div class="panel-title">Add Block</div>
            <div class="block-palette">
              <button class="block-btn" data-add-block="hero">${icons.section}<span>Hero</span></button>
              <button class="block-btn" data-add-block="section">${icons.type}<span>Section</span></button>
              <button class="block-btn" data-add-block="split">${icons.layout}<span>Text + Image</span></button>
              <button class="block-btn" data-add-block="pricing">${icons.dollar}<span>Pricing</span></button>
              <button class="block-btn" data-add-block="divider">${icons.minus}<span>Divider</span></button>
              <button class="block-btn" data-add-block="accept">${icons.check}<span>Sign Off</span></button>
            </div>
          </div>
        </div>
        <div class="editor-main">
          <div class="quote-canvas">
            ${currentQuote.blocks.length === 0 ? '<div class="empty-state"><p class="empty-desc">Add blocks to build your proposal</p></div>' : currentQuote.blocks.map(b => renderBlock(b)).join('')}
          </div>
        </div>
      </div>
    `;
  }

  function renderBlock(block: Block): string {
    const toolbar = `<div class="block-toolbar">
      <button data-move-up="${block.id}">${icons.arrowUp}</button>
      <button data-move-down="${block.id}">${icons.arrowDown}</button>
      ${block.type === 'section' ? `<button data-ai-assist="${block.id}" title="AI Assistant">${icons.sparkle}</button>` : ''}
      ${block.type === 'pricing' ? `<button data-edit-pricing="${block.id}">${icons.edit}</button>` : ''}
      <button data-remove-block="${block.id}">${icons.trash}</button>
    </div>`;

    switch (block.type) {
      case 'hero':
        const themeClass = currentQuote?.heroTheme && currentQuote.heroTheme !== 'gradient' ? `theme-${currentQuote.heroTheme}` : '';
        return `<div class="block-item block-hero ${themeClass}">${toolbar}<h1 contenteditable="true" data-field="title" data-block="${block.id}">${block.title}</h1><p contenteditable="true" data-field="subtitle" data-block="${block.id}">${block.subtitle}</p></div>`;

      case 'section':
        return `<div class="block-item block-section">${toolbar}<h2 contenteditable="true" data-field="title" data-block="${block.id}">${block.title}</h2><div contenteditable="true" data-field="content" data-block="${block.id}">${block.content}</div></div>`;

      case 'pricing':
        const total = block.items.reduce((sum, i) => i.selected ? sum + (Number(i.quantity) * Number(i.unitPrice)) : sum, 0);
        return `<div class="block-item block-pricing">${toolbar}<h3>${block.title}</h3>
          <table class="pricing-table"><thead><tr><th>Item</th><th style="text-align:right">Unit Price</th><th style="text-align:center">Qty</th><th style="text-align:right">Total</th></tr></thead><tbody>
          ${block.items.map(item => `<tr><td><div class="item-name">${item.name}${item.optional ? ' (Optional)' : ''}</div><div class="item-desc">${item.description}</div></td><td style="text-align:right">${formatCurrency(item.unitPrice)}</td><td style="text-align:center">${item.quantity}</td><td class="item-price" style="text-align:right">${formatCurrency(Number(item.quantity) * Number(item.unitPrice))}</td></tr>`).join('')}
          </tbody></table>
          ${block.showTotal ? `<div class="pricing-total"><span>Total</span><span class="amount">${formatCurrency(total)}</span></div>` : ''}</div>`;

      case 'divider':
        return `<div class="block-item block-divider">${toolbar}<hr></div>`;

      case 'accept':
        return `<div class="block-item block-accept">${toolbar}<p class="terms" contenteditable="true" data-field="terms" data-block="${block.id}">${block.terms}</p><button class="accept-btn">${block.buttonText}</button></div>`;

      case 'split':
        return `<div class="block-item block-split">${toolbar}
          <div class="block-split-content">
            <h2 contenteditable="true" data-field="title" data-block="${block.id}">${block.title}</h2>
            <p contenteditable="true" data-field="content" data-block="${block.id}">${block.content}</p>
          </div>
          <div class="block-split-image" data-paste-target="${block.id}" tabindex="0">
            ${block.imageUrl
              ? `<img src="${block.imageUrl}" alt=""><button class="btn btn-ghost btn-sm" style="position:absolute;top:8px;right:8px" data-remove-image="${block.id}">${icons.x}</button>`
              : `<div class="upload-placeholder">
                  <div class="image-search-inline">
                    <input type="text" class="form-input" placeholder="Search for an image..." data-image-query="${block.id}">
                    <button class="btn btn-sm btn-primary" data-search-image="${block.id}">${icons.search}</button>
                  </div>
                  <div class="image-actions-row">
                    <label class="image-action-btn"><input type="file" accept="image/*" data-split-image="${block.id}" hidden>${icons.image} Upload</label>
                    <span class="image-divider">or</span>
                    <span class="image-paste-hint">paste image here</span>
                  </div>
                </div>`}
          </div>
        </div>`;

      default:
        return '';
    }
  }

  function renderSlidesList(): string {
    // Show creating state
    if (creatingSlidesFromQuoteId) {
      const selectedQuote = quotes.find(q => q.id === creatingSlidesFromQuoteId);
      return `
        <div class="page-header"><h1 class="page-title">Slides</h1></div>
        <div class="empty-state">
          <div class="creating-slides-spinner"></div>
          <h2 class="empty-title" style="margin-top:24px">Creating slides...</h2>
          <p class="empty-desc">${selectedQuote?.title || ''}</p>
        </div>
      `;
    }

    if (slideshows.length === 0) {
      return `
        <div class="page-header"><h1 class="page-title">Slides</h1></div>
        <div class="empty-state">
          <div class="empty-icon">${icons.slides}</div>
          <h2 class="empty-title">No slides yet</h2>
          <p class="empty-desc">Create visual slide decks from your quotes</p>
          <button class="btn btn-primary" data-action="create-slideshow">${icons.plus} Create from Quote</button>
        </div>
      `;
    }

    return `
      <div class="page-header">
        <h1 class="page-title">Slides</h1>
        <button class="btn btn-primary" data-action="create-slideshow">${icons.plus} Create from Quote</button>
      </div>
      <div class="templates-grid">
        ${slideshows.map(p => {
          const sourceQuote = quotes.find(q => q.id === p.sourceQuoteId);
          return `
            <div class="template-card" data-edit-slideshow="${p.id}">
              <div class="template-preview slideshow-card-preview theme-${p.theme}">
                <h3>${p.title}</h3>
                <p>${p.slides.length} slides</p>
              </div>
              <div class="template-info">
                <div class="template-name">${p.title}</div>
                <div class="template-desc">From: ${sourceQuote?.clientName || 'Unknown'} • ${formatDate(p.updatedAt)}</div>
              </div>
            </div>
          `;
        }).join('')}
      </div>
    `;
  }

  function renderQuotePicker(): string {
    if (quotes.length === 0) {
      return `
        <div class="modal-body">
          <p style="color:var(--text-muted)">No quotes available. Create a quote first.</p>
        </div>
        <div class="modal-footer">
          <button class="btn btn-secondary" data-close-modal>Cancel</button>
        </div>
      `;
    }

    if (creatingSlidesFromQuoteId) {
      const selectedQuote = quotes.find(q => q.id === creatingSlidesFromQuoteId);
      return `
        <div class="modal-body" style="text-align:center;padding:40px">
          <div class="creating-slides-spinner"></div>
          <h3 style="margin-top:20px">Creating slides...</h3>
          <p style="color:var(--text-muted);margin-top:8px">${selectedQuote?.title || ''}</p>
        </div>
      `;
    }

    return `
      <div class="modal-body">
        <p style="margin-bottom:20px;color:var(--text-muted)">Select a quote to create slides from:</p>
        <div class="quote-picker-list">
          ${quotes.map(q => `
            <div class="quote-picker-item" data-select-quote="${q.id}">
              <div class="quote-picker-title">${q.title}</div>
              <div class="quote-picker-meta">${q.clientName || 'No client'} • ${formatCurrency(q.total)}</div>
              <div class="quote-picker-arrow">${icons.arrowRight}</div>
            </div>
          `).join('')}
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" data-close-modal>Cancel</button>
      </div>
    `;
  }

  function renderSlidesEditor(): string {
    if (!currentSlideshow) return '';

    return `
      <div class="page-header">
        <button class="btn btn-ghost" data-action="back-to-slides">← Back</button>
        <div style="display:flex;gap:12px;align-items:center">
          <button class="btn btn-secondary btn-sm" data-action="delete-slideshow" style="color:#ff4444;border-color:#ff4444">${icons.x} Delete</button>
          <button class="btn btn-success" data-action="start-slideshow">${icons.play} Present</button>
          <button class="btn btn-primary" data-action="save-slideshow">${saving ? 'Saving...' : `${icons.check} Save`}</button>
        </div>
      </div>
      <div class="slides-editor-layout">
        <div class="slides-sidebar">
          <div class="editor-panel">
            <div class="panel-title">Slides</div>
            <div class="slide-thumbnails">
              ${currentSlideshow.slides.map((slide, i) => `
                <div class="slide-thumb ${i === currentSlideIndex ? 'active' : ''}" data-select-slide="${i}">
                  <div class="slide-thumb-number">${i + 1}</div>
                  <div class="slide-thumb-content">
                    <div class="slide-thumb-type">${slide.type}</div>
                    <div class="slide-thumb-headline">${slide.headline || '(empty)'}</div>
                  </div>
                  <button class="slide-thumb-delete" data-delete-slide="${i}">${icons.x}</button>
                </div>
              `).join('')}
            </div>
            <button class="add-item-btn" data-action="add-slide">+ Add Slide</button>
          </div>
          <div class="editor-panel">
            <div class="panel-title">Details</div>
            <div class="form-group">
              <label class="form-label">Title</label>
              <input class="form-input" type="text" id="slideshow-title" value="${currentSlideshow.title}">
            </div>
            ${currentSlideshow.clientName ? `<div class="form-group"><label class="form-label">Client</label><div style="color:var(--text)">${currentSlideshow.clientName}</div></div>` : ''}
          </div>
        </div>
        <div class="slides-main">
          <div class="slides-top-toolbar">
            <div class="slides-theme-bar">
              <span class="toolbar-label">Theme:</span>
              <div class="slides-theme-swatch ${currentSlideshow.theme === 'dark' ? 'active' : ''}" data-slides-theme="dark">Dark</div>
              <div class="slides-theme-swatch ${currentSlideshow.theme === 'light' ? 'active' : ''}" data-slides-theme="light">Light</div>
              <div class="slides-theme-swatch ${currentSlideshow.theme === 'gradient' ? 'active' : ''}" data-slides-theme="gradient">Gradient</div>
              <div class="slides-theme-swatch ${currentSlideshow.theme === 'minimal' ? 'active' : ''}" data-slides-theme="minimal">Minimal</div>
              <div class="slides-theme-swatch ${currentSlideshow.theme === 'bold' ? 'active' : ''}" data-slides-theme="bold">Bold</div>
              ${currentSlideshow.brandColor ? `<div class="slides-theme-swatch ${currentSlideshow.theme === 'brand' ? 'active' : ''}" data-slides-theme="brand" style="background:${currentSlideshow.brandColor};color:#fff">Brand</div>` : ''}
            </div>
            <div class="slides-branding-bar">
              <img src="${BRIDGEPOINT_LOGO}" alt="Bridge Point" class="toolbar-logo">
              ${currentSlideshow.clientLogo ? `<img src="${currentSlideshow.clientLogo}" alt="${currentSlideshow.clientName || 'Client'}" class="toolbar-logo">` : ''}
            </div>
          </div>
          ${renderSlideEditor()}
        </div>
      </div>
    `;
  }

  function renderSlideEditor(): string {
    if (!currentSlideshow || currentSlideIndex >= currentSlideshow.slides.length) return '';
    const slide = currentSlideshow.slides[currentSlideIndex];

    return `
      <div class="slide-editor-preview theme-${currentSlideshow.theme}">
        <div class="slide-content slide-type-${slide.type}">
          ${slide.type === 'title' ? `
            <input class="slide-headline-input" type="text" value="${slide.headline || ''}" data-slide-field="headline" placeholder="Headline">
            <input class="slide-subtitle-input" type="text" value="${slide.bullets?.[0] || ''}" data-slide-field="subtitle" placeholder="Subtitle">
          ` : ''}
          ${slide.type === 'content' ? `
            <input class="slide-headline-input" type="text" value="${slide.headline || ''}" data-slide-field="headline" placeholder="Headline">
            <div class="slide-bullets-editor">
              ${(slide.bullets || []).map((b, i) => `
                <div class="slide-bullet-row">
                  <span class="slide-bullet-dot">•</span>
                  <input class="slide-bullet-input" type="text" value="${b}" data-bullet-index="${i}" placeholder="Bullet point">
                  <button class="slide-bullet-delete" data-delete-bullet="${i}">${icons.x}</button>
                </div>
              `).join('')}
              <button class="add-item-btn" data-action="add-bullet">+ Add Point</button>
            </div>
          ` : ''}
          ${slide.type === 'visual' ? `
            <input class="slide-headline-input" type="text" value="${slide.headline || ''}" data-slide-field="headline" placeholder="Headline">
            <div class="slide-visual-area">
              ${slide.image ? `<img src="${slide.image}" class="slide-visual-image">` : '<div class="slide-visual-placeholder">No image</div>'}
            </div>
          ` : ''}
          ${slide.type === 'data' ? `
            <input class="slide-headline-input" type="text" value="${slide.headline || ''}" data-slide-field="headline" placeholder="Headline">
            <div class="slide-stats-grid">
              ${(slide.stats || []).map((s, i) => `
                <div class="slide-stat-item">
                  <input class="slide-stat-value" type="text" value="${s.value}" data-stat-index="${i}" data-stat-field="value" placeholder="Value">
                  <input class="slide-stat-label" type="text" value="${s.label}" data-stat-index="${i}" data-stat-field="label" placeholder="Label">
                </div>
              `).join('')}
            </div>
          ` : ''}
          ${slide.type === 'break' ? `
            <div class="slide-break-visual">
              <div class="slide-break-line"></div>
            </div>
          ` : ''}
        </div>
      </div>
      <div class="slide-type-picker">
        <label class="form-label">Slide Type</label>
        <select class="form-input" id="slide-type-select">
          <option value="title" ${slide.type === 'title' ? 'selected' : ''}>Title</option>
          <option value="content" ${slide.type === 'content' ? 'selected' : ''}>Content</option>
          <option value="visual" ${slide.type === 'visual' ? 'selected' : ''}>Visual</option>
          <option value="data" ${slide.type === 'data' ? 'selected' : ''}>Data</option>
          <option value="break" ${slide.type === 'break' ? 'selected' : ''}>Break</option>
        </select>
      </div>
    `;
  }

  function renderSlidesView(): string {
    if (!currentSlideshow || currentSlideshow.slides.length === 0) return '';
    const slide = currentSlideshow.slides[currentSlideIndex];
    const brandStyle = currentSlideshow.theme === 'brand' && currentSlideshow.brandColor
      ? `style="--brand-color: ${currentSlideshow.brandColor}; background: linear-gradient(135deg, ${currentSlideshow.brandColor}, #1a1a2e)"`
      : '';

    return `
      <div class="slideshow-container theme-${currentSlideshow.theme}" ${brandStyle}>
        <div class="slideshow-logos">
          <img src="${BRIDGEPOINT_LOGO}" alt="Bridge Point" class="slideshow-logo">
          ${currentSlideshow.clientLogo ? `<img src="${currentSlideshow.clientLogo}" alt="${currentSlideshow.clientName || ''}" class="slideshow-logo slideshow-logo-client">` : ''}
        </div>
        <div class="slideshow-slide slide-type-${slide.type}">
          ${slide.type === 'title' ? `
            <h1 class="slideshow-headline">${slide.headline || ''}</h1>
            ${slide.bullets?.[0] ? `<p class="slideshow-subtitle">${slide.bullets[0]}</p>` : ''}
          ` : ''}
          ${slide.type === 'content' ? `
            <h2 class="slideshow-headline">${slide.headline || ''}</h2>
            <ul class="slideshow-bullets">
              ${(slide.bullets || []).map(b => `<li>${b}</li>`).join('')}
            </ul>
          ` : ''}
          ${slide.type === 'visual' ? `
            <h2 class="slideshow-headline">${slide.headline || ''}</h2>
            ${slide.image ? `<img src="${slide.image}" class="slideshow-image">` : ''}
          ` : ''}
          ${slide.type === 'data' ? `
            <h2 class="slideshow-headline">${slide.headline || ''}</h2>
            <div class="slideshow-stats">
              ${(slide.stats || []).map(s => `
                <div class="slideshow-stat">
                  <div class="slideshow-stat-value">${s.value}</div>
                  <div class="slideshow-stat-label">${s.label}</div>
                </div>
              `).join('')}
            </div>
          ` : ''}
          ${slide.type === 'break' ? `
            <div class="slideshow-break"></div>
          ` : ''}
        </div>
        <div class="slideshow-controls">
          <button class="slideshow-nav" data-action="prev-slide" ${currentSlideIndex === 0 ? 'disabled' : ''}>${icons.arrowLeft}</button>
          <div class="slideshow-progress">
            <span>${currentSlideIndex + 1} / ${currentSlideshow.slides.length}</span>
            <div class="slideshow-progress-bar">
              <div class="slideshow-progress-fill" style="width: ${((currentSlideIndex + 1) / currentSlideshow.slides.length) * 100}%"></div>
            </div>
          </div>
          <button class="slideshow-nav" data-action="next-slide" ${currentSlideIndex >= currentSlideshow.slides.length - 1 ? 'disabled' : ''}>${icons.arrowRight}</button>
        </div>
        <button class="slideshow-exit" data-action="exit-slideshow">${icons.x} Exit</button>
      </div>
    `;
  }

  function renderAssets(): string {
    const filteredAssets = assets.filter(a => {
      if (assetFilter !== 'all' && a.type !== assetFilter) return false;
      if (assetSearch && !a.name.toLowerCase().includes(assetSearch.toLowerCase()) &&
          !a.clientName?.toLowerCase().includes(assetSearch.toLowerCase()) &&
          !a.tags.some(t => t.toLowerCase().includes(assetSearch.toLowerCase()))) return false;
      return true;
    });

    return `
      <div class="page-header">
        <h1 class="page-title">Assets</h1>
        <button class="btn btn-primary" data-action="add-asset">${icons.plus} Add Asset</button>
      </div>

      ${showAssetUpload ? `
        <div class="asset-upload-panel">
          <div class="asset-upload-tabs">
            <button class="asset-tab active" data-asset-tab="upload">${icons.upload} Upload Image</button>
            <button class="asset-tab" data-asset-tab="url">${icons.globe} Add URL</button>
          </div>
          <div class="asset-upload-content">
            <div class="asset-upload-dropzone" data-asset-dropzone>
              <input type="file" id="asset-file-input" accept="image/*" style="display:none" multiple onchange="handleAssetFiles(this)">
              <div class="dropzone-content">
                ${icons.upload}
                <p>Drop images here or <span class="dropzone-link" onclick="event.stopPropagation(); document.getElementById('asset-file-input').click();">browse</span></p>
                <span class="dropzone-hint">PNG, JPG, SVG up to 10MB</span>
              </div>
            </div>
            <div class="asset-url-form" style="display:none">
              <div class="form-group">
                <label class="form-label">Website URL</label>
                <input class="form-input" type="url" id="asset-url-input" placeholder="https://example.com">
              </div>
              <div class="form-group">
                <label class="form-label">Name (optional)</label>
                <input class="form-input" type="text" id="asset-name-input" placeholder="Client name">
              </div>
              <button class="btn btn-primary" data-action="save-url-asset">${icons.plus} Add Website</button>
            </div>
          </div>
          <button class="asset-upload-close" data-action="close-asset-upload">${icons.x}</button>
        </div>
      ` : ''}

      <div class="assets-toolbar">
        <div class="assets-filters">
          <button class="filter-btn ${assetFilter === 'all' ? 'active' : ''}" data-asset-filter="all">All</button>
          <button class="filter-btn ${assetFilter === 'logo' ? 'active' : ''}" data-asset-filter="logo">${icons.image} Logos</button>
          <button class="filter-btn ${assetFilter === 'image' ? 'active' : ''}" data-asset-filter="image">${icons.image} Images</button>
          <button class="filter-btn ${assetFilter === 'url' ? 'active' : ''}" data-asset-filter="url">${icons.globe} URLs</button>
        </div>
        <div class="assets-search">
          <input class="form-input" type="text" id="asset-search" placeholder="Search assets..." value="${assetSearch}">
        </div>
      </div>

      ${filteredAssets.length === 0 ? `
        <div class="empty-state">
          <div class="empty-icon">${icons.assets}</div>
          <h2 class="empty-title">${assets.length === 0 ? 'No assets yet' : 'No matches'}</h2>
          <p class="empty-desc">${assets.length === 0 ? 'Upload images or add website URLs to build your asset library' : 'Try a different search or filter'}</p>
        </div>
      ` : `
        <div class="assets-grid">
          ${filteredAssets.map(asset => `
            <div class="asset-card" data-asset-id="${asset.id}">
              <div class="asset-preview ${asset.type === 'url' ? 'asset-preview-url' : ''}" ${asset.brandColor ? `style="background-color: ${asset.brandColor}"` : ''}>
                ${asset.thumbnail || asset.imageData ? `
                  <img src="${asset.thumbnail || asset.imageData}" alt="${asset.name}">
                ` : asset.type === 'url' ? `
                  <div class="asset-url-icon">${icons.globe}</div>
                ` : `
                  <div class="asset-placeholder">${icons.image}</div>
                `}
                <div class="asset-type-badge">${asset.type}</div>
              </div>
              <div class="asset-info">
                <div class="asset-name">${asset.name}</div>
                ${asset.clientName ? `<div class="asset-client">${asset.clientName}</div>` : ''}
                ${asset.tags.length > 0 ? `
                  <div class="asset-tags">
                    ${asset.tags.map(t => `<span class="asset-tag">${t}</span>`).join('')}
                  </div>
                ` : ''}
              </div>
              <div class="asset-actions">
                <button class="asset-action-btn" data-copy-asset="${asset.id}" title="Copy">${icons.copy}</button>
                <button class="asset-action-btn asset-delete" data-delete-asset="${asset.id}" title="Delete">${icons.x}</button>
              </div>
            </div>
          `).join('')}
        </div>
      `}
    `;
  }

  function renderModal(): string {
    if (modalType === 'send' && currentQuote) {
      return `<div class="modal-overlay" data-close-modal><div class="modal">
        <div class="modal-header"><h3 class="modal-title">Send Quote</h3><button class="modal-close" data-close-modal>${icons.x}</button></div>
        <div class="modal-body">
          <p style="margin-bottom:20px;color:var(--text-muted)">Send this proposal to your client via email.</p>
          <div class="form-group"><label class="form-label">Client Email</label><input class="form-input" type="email" id="send-email" value="${currentQuote.clientEmail}" placeholder="client@example.com"></div>
          <div class="form-group"><label class="form-label">Client Name</label><input class="form-input" type="text" id="send-name" value="${currentQuote.clientName}" placeholder="Client name"></div>
        </div>
        <div class="modal-footer">
          <button class="btn btn-secondary" data-close-modal>Cancel</button>
          <button class="btn btn-success" data-action="send-quote" ${sending ? 'disabled' : ''}>${sending ? 'Sending...' : 'Send Quote'}</button>
        </div>
      </div></div>`;
    }

    if (modalType === 'pricing' && editingPricingBlock) {
      return `<div class="modal-overlay" data-close-modal><div class="modal" style="max-width:700px">
        <div class="modal-header"><h3 class="modal-title">Edit Pricing</h3><button class="modal-close" data-close-modal>${icons.x}</button></div>
        <div class="modal-body">
          <div class="form-group"><label class="form-label">Section Title</label><input class="form-input" type="text" id="pricing-title" value="${editingPricingBlock.title}"></div>
          <div class="pricing-editor">
            ${editingPricingBlock.items.map((item, i) => `
              <div class="pricing-item-row">
                <div class="item-fields">
                  <input class="form-input" type="text" data-item="${i}" data-field="name" value="${item.name}" placeholder="Item name">
                  <input class="form-input" type="text" data-item="${i}" data-field="description" value="${item.description}" placeholder="Description">
                </div>
                <input class="form-input" type="number" data-item="${i}" data-field="quantity" value="${item.quantity}" placeholder="Qty" style="width:70px">
                <input class="form-input" type="number" data-item="${i}" data-field="unitPrice" value="${item.unitPrice}" placeholder="Price">
                <label style="display:flex;align-items:center;gap:6px;font-size:0.8rem;color:var(--text-muted)"><input type="checkbox" data-item="${i}" data-field="optional" ${item.optional ? 'checked' : ''}> Optional</label>
                <button type="button" class="delete-item-btn" data-delete-item="${i}" title="Delete item">${icons.trash}</button>
              </div>
            `).join('')}
            <button class="add-item-btn" data-action="add-pricing-item">+ Add Item</button>
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn btn-secondary" data-close-modal>Cancel</button>
          <button class="btn btn-primary" data-action="save-pricing">Save Pricing</button>
        </div>
      </div></div>`;
    }

    if (modalType === 'ai') {
      return `<div class="modal-overlay" data-close-modal><div class="modal" style="max-width:600px">
        <div class="modal-header"><h3 class="modal-title">${icons.sparkle} AI Assistant</h3><button class="modal-close" data-close-modal>${icons.x}</button></div>
        <div class="modal-body">
          <div class="ai-prompt-area">
            <label class="form-label">What would you like in this section?</label>
            <textarea class="form-input form-textarea" id="ai-prompt" placeholder="e.g. In simple terms and use bullet points, explain the benefits of EDR (advanced AV)">${aiPrompt}</textarea>
          </div>
          <button class="btn btn-primary" data-action="generate-ai" ${aiGenerating ? 'disabled' : ''}>${aiGenerating ? 'Generating...' : `${icons.sparkle} Generate`}</button>
          ${aiOutput ? `<div class="ai-output">${aiOutput}</div>` : ''}
        </div>
        <div class="modal-footer">
          <button class="btn btn-secondary" data-close-modal>Cancel</button>
          <button class="btn btn-success" data-action="use-ai-output" ${!aiOutput ? 'disabled' : ''}>Use This Content</button>
        </div>
      </div></div>`;
    }

    if (modalType === 'quote-picker') {
      return `<div class="modal-overlay" data-close-modal><div class="modal">
        <div class="modal-header"><h3 class="modal-title">Create Slideshow</h3><button class="modal-close" data-close-modal>${icons.x}</button></div>
        ${renderQuotePicker()}
      </div></div>`;
    }

    return '';
  }

  function attachListeners() {
    document.querySelectorAll('[data-view]').forEach(btn => btn.addEventListener('click', () => { view = (btn as HTMLElement).dataset.view as typeof view; render(); }));
    document.querySelectorAll('[data-action="new-quote"]').forEach(btn => btn.addEventListener('click', () => { view = 'templates'; render(); }));

    document.querySelector('[data-action="force-sync"]')?.addEventListener('click', async () => {
      localStorage.removeItem(LOCAL_STORAGE_KEY);
      quotes = [];
      loading = true;
      render();
      await loadQuotes();
      showToast('Synced from cloud');
    });
    document.querySelectorAll('[data-template]').forEach(card => card.addEventListener('click', () => { const t = templates.find(t => t.id === (card as HTMLElement).dataset.template); if (t) createFromTemplate(t); }));

    document.querySelectorAll('[data-edit-quote]').forEach(row => row.addEventListener('click', () => {
      const id = (row as HTMLElement).dataset.editQuote;
      currentQuote = JSON.parse(JSON.stringify(quotes.find(q => q.id === id)));
      view = 'editor';
      render();
    }));

    document.querySelectorAll('[data-action="edit"]').forEach(btn => btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const id = (btn as HTMLElement).dataset.id;
      currentQuote = JSON.parse(JSON.stringify(quotes.find(q => q.id === id)));
      view = 'editor';
      render();
    }));

    document.querySelectorAll('[data-action="send"]').forEach(btn => btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const id = (btn as HTMLElement).dataset.id;
      currentQuote = JSON.parse(JSON.stringify(quotes.find(q => q.id === id)));
      modalType = 'send';
      showModal = true;
      render();
    }));

    document.querySelectorAll('[data-action="delete"]').forEach(btn => btn.addEventListener('click', (e) => { e.stopPropagation(); const id = (btn as HTMLElement).dataset.id; if (id) deleteQuote(id); }));

    document.querySelectorAll('[data-action="pdf"]').forEach(btn => btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const id = (btn as HTMLElement).dataset.id;
      if (id) window.open(`/view?id=${id}&print=1`, '_blank');
    }));

    document.querySelector('[data-action="back"]')?.addEventListener('click', () => { view = 'dashboard'; currentQuote = null; render(); });

    document.querySelector('[data-action="save"]')?.addEventListener('click', async () => {
      if (currentQuote) {
        currentQuote.title = (document.getElementById('quote-title') as HTMLInputElement)?.value || currentQuote.title;
        currentQuote.clientName = (document.getElementById('quote-client') as HTMLInputElement)?.value || '';
        currentQuote.clientEmail = (document.getElementById('quote-email') as HTMLInputElement)?.value || '';
        currentQuote.clientWebsite = (document.getElementById('quote-website') as HTMLInputElement)?.value || '';
        currentQuote.status = (document.getElementById('quote-status') as HTMLSelectElement)?.value as Quote['status'] || currentQuote.status;
        currentQuote.showHeader = (document.getElementById('quote-show-header') as HTMLInputElement)?.checked ?? true;
        currentQuote.logoNeedsBackground = (document.getElementById('quote-logo-background') as HTMLInputElement)?.checked ?? false;
      }
      await saveCurrentQuote();
    });

    document.querySelector('[data-action="delete-quote"]')?.addEventListener('click', async () => {
      if (!currentQuote) return;
      if (!confirm('Delete this quote permanently?')) return;
      quotes = quotes.filter(q => q.id !== currentQuote!.id);
      await saveQuotes();
      currentQuote = null;
      view = 'dashboard';
      showToast('Quote deleted');
      render();
    });

    // Logo upload handler
    document.getElementById('quote-logo-upload')?.addEventListener('change', async (e) => {
      const input = e.target as HTMLInputElement;
      const file = input.files?.[0];
      if (!file || !currentQuote) return;

      // Convert logo to base64 directly (avoids CORS issues in PDF generation)
      try {
        const base64 = await new Promise<string>((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => resolve(reader.result as string);
          reader.onerror = () => reject(new Error('Failed to read file'));
          reader.readAsDataURL(file);
        });

        currentQuote.clientLogo = base64;
        // Also grab latest form values before saving
        currentQuote.title = (document.getElementById('quote-title') as HTMLInputElement)?.value || currentQuote.title;
        currentQuote.clientName = (document.getElementById('quote-client') as HTMLInputElement)?.value || '';
        currentQuote.clientEmail = (document.getElementById('quote-email') as HTMLInputElement)?.value || '';
        currentQuote.clientWebsite = (document.getElementById('quote-website') as HTMLInputElement)?.value || '';
        await saveCurrentQuote();
        render();
      } catch (err) {
        alert('Failed to upload logo');
      }
    });

    // Split block image upload (use event delegation since inputs are dynamic)
    document.addEventListener('change', async (e) => {
      const input = e.target as HTMLInputElement;
      if (!input.dataset.splitImage || !currentQuote) return;

      const blockId = input.dataset.splitImage;
      const file = input.files?.[0];
      if (!file) return;

      try {
        // Compress image to max 800px width
        const compressedBase64 = await compressImage(file, 800);

        const block = currentQuote.blocks.find(b => b.id === blockId);
        if (block && block.type === 'split') {
          (block as any).imageUrl = compressedBase64;
          render();
          showToast('Image added - click Save to keep it');
        }
      } catch (err) {
        showToast('Failed to upload image');
      }
    });

    document.querySelector('[data-action="preview"]')?.addEventListener('click', () => { if (currentQuote) window.open(`/view?id=${currentQuote.id}`, '_blank'); });

    document.querySelector('[data-action="duplicate"]')?.addEventListener('click', async () => {
      if (!currentQuote) return;
      const now = Date.now();
      const duplicatedQuote: Quote = {
        ...JSON.parse(JSON.stringify(currentQuote)),
        id: genId(),
        title: `Copy of ${currentQuote.title}`,
        status: 'draft',
        createdAt: now,
        updatedAt: now,
        viewCount: 0
      };
      quotes.unshift(duplicatedQuote);
      await saveQuotes();
      currentQuote = duplicatedQuote;
      showToast('Quote duplicated!');
      render();
    });

    document.querySelector('[data-action="copy-link"]')?.addEventListener('click', () => {
      if (currentQuote) {
        navigator.clipboard.writeText(`${window.location.origin}/view?id=${currentQuote.id}`);
        showToast('Link copied!');
      }
    });

    document.querySelector('[data-action="send-modal"]')?.addEventListener('click', () => {
      if (currentQuote) {
        currentQuote.title = (document.getElementById('quote-title') as HTMLInputElement)?.value || currentQuote.title;
        currentQuote.clientName = (document.getElementById('quote-client') as HTMLInputElement)?.value || '';
        currentQuote.clientEmail = (document.getElementById('quote-email') as HTMLInputElement)?.value || '';
      }
      modalType = 'send';
      showModal = true;
      render();
    });

    document.querySelector('[data-action="send-quote"]')?.addEventListener('click', async () => {
      if (currentQuote) {
        currentQuote.clientEmail = (document.getElementById('send-email') as HTMLInputElement)?.value || '';
        currentQuote.clientName = (document.getElementById('send-name') as HTMLInputElement)?.value || '';
      }
      await sendQuote();
    });

    document.querySelectorAll('[data-add-block]').forEach(btn => btn.addEventListener('click', () => addBlock((btn as HTMLElement).dataset.addBlock as Block['type'])));
    document.querySelectorAll('[data-remove-block]').forEach(btn => btn.addEventListener('click', () => removeBlock((btn as HTMLElement).dataset.removeBlock!)));
    document.querySelectorAll('[data-move-up]').forEach(btn => btn.addEventListener('click', () => moveBlock((btn as HTMLElement).dataset.moveUp!, -1)));
    document.querySelectorAll('[data-move-down]').forEach(btn => btn.addEventListener('click', () => moveBlock((btn as HTMLElement).dataset.moveDown!, 1)));
    document.querySelectorAll('[data-edit-pricing]').forEach(btn => btn.addEventListener('click', () => editPricing((btn as HTMLElement).dataset.editPricing!)));

    document.querySelectorAll('[contenteditable]').forEach(el => {
      el.addEventListener('blur', () => {
        const blockId = (el as HTMLElement).dataset.block;
        const field = (el as HTMLElement).dataset.field;
        if (!blockId || !field || !currentQuote) return;
        const block = currentQuote.blocks.find(b => b.id === blockId);
        if (block && field in block) (block as any)[field] = (el as HTMLElement).innerText;
      });
    });

    document.querySelectorAll('[data-close-modal]').forEach(el => {
      el.addEventListener('click', (e) => { if (e.target === el) { showModal = false; editingPricingBlock = null; render(); } });
    });

    // Pricing editor
    document.querySelector('#pricing-title')?.addEventListener('input', (e) => {
      if (editingPricingBlock) editingPricingBlock.title = (e.target as HTMLInputElement).value;
    });

    document.querySelectorAll('.pricing-item-row input, .pricing-item-row select').forEach(input => {
      input.addEventListener('change', () => {
        const el = input as HTMLInputElement;
        const idx = parseInt(el.dataset.item || '0');
        const field = el.dataset.field;
        if (!editingPricingBlock || !field) return;
        const item = editingPricingBlock.items[idx];
        if (!item) return;
        if (field === 'optional') item.optional = el.checked;
        else if (field === 'quantity') item.quantity = parseInt(el.value) || 1;
        else if (field === 'unitPrice') item.unitPrice = parseFloat(el.value) || 0;
        else (item as any)[field] = el.value;
      });
    });

    document.querySelector('[data-action="add-pricing-item"]')?.addEventListener('click', () => {
      if (editingPricingBlock) {
        editingPricingBlock.items.push({ id: genId(), name: 'New Item', description: '', quantity: 1, unitPrice: 0, optional: false, selected: true });
        render();
      }
    });

    document.querySelectorAll('[data-delete-item]').forEach(btn => {
      btn.addEventListener('click', () => {
        if (editingPricingBlock) {
          const idx = parseInt((btn as HTMLElement).dataset.deleteItem!);
          editingPricingBlock.items.splice(idx, 1);
          render();
        }
      });
    });

    document.querySelector('[data-action="save-pricing"]')?.addEventListener('click', savePricingEdit);

    // Theme swatch clicks
    document.querySelectorAll('.theme-swatch').forEach(swatch => {
      swatch.addEventListener('click', () => {
        if (!currentQuote) return;
        currentQuote.heroTheme = (swatch as HTMLElement).dataset.theme as Quote['heroTheme'];
        render();
      });
    });

    // PDF button
    document.querySelector('[data-action="pdf"]')?.addEventListener('click', () => {
      if (currentQuote) {
        window.open(`/view?id=${currentQuote.id}&print=1`, '_blank');
      }
    });

    // AI assist button on sections
    document.querySelectorAll('[data-ai-assist]').forEach(btn => {
      btn.addEventListener('click', () => {
        aiTargetBlockId = (btn as HTMLElement).dataset.aiAssist!;
        aiPrompt = '';
        aiOutput = '';
        modalType = 'ai';
        showModal = true;
        render();
      });
    });

    // AI generate button
    document.querySelector('[data-action="generate-ai"]')?.addEventListener('click', async () => {
      const promptEl = document.getElementById('ai-prompt') as HTMLTextAreaElement;
      aiPrompt = promptEl?.value || '';
      if (!aiPrompt.trim()) return;

      aiGenerating = true;
      render();

      try {
        const fullPrompt = `You are a professional business proposal writer for Bridge Point, a technology consultancy. Generate content for a proposal section based on this request:

${aiPrompt}

Rules:
- Be professional but approachable
- Use bullet points where appropriate
- Be concise and clear
- Focus on benefits and value
- Don't use overly technical jargon unless requested
- Return ONLY the content, no headers or section titles`;

        const resp = await fetch(WORKER_URL + '/drafty-polish', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ prompt: fullPrompt })
        });
        const data = await resp.json();
        aiOutput = data.text || data.error || 'No output generated';
      } catch (err) {
        aiOutput = 'Failed to generate content';
      }

      aiGenerating = false;
      render();
    });

    // Use AI output
    document.querySelector('[data-action="use-ai-output"]')?.addEventListener('click', () => {
      if (!currentQuote || !aiTargetBlockId || !aiOutput) return;
      const block = currentQuote.blocks.find(b => b.id === aiTargetBlockId);
      if (block && block.type === 'section') {
        (block as any).content = aiOutput;
      }
      showModal = false;
      aiOutput = '';
      aiPrompt = '';
      render();
    });

    // Inline image search
    document.querySelectorAll('[data-search-image]').forEach(btn => {
      btn.addEventListener('click', () => {
        const blockId = (btn as HTMLElement).dataset.searchImage!;
        const input = document.querySelector(`[data-image-query="${blockId}"]`) as HTMLInputElement;
        const query = input?.value?.trim();
        if (!query) {
          input?.focus();
          return;
        }
        const searchUrl = `https://www.google.com/search?tbm=isch&q=${encodeURIComponent(query)}`;
        window.open(searchUrl, '_blank');
        showToast('Find an image, right-click → Copy Image, then paste here');
      });
    });

    // Handle Enter key in inline search
    document.querySelectorAll('[data-image-query]').forEach(input => {
      input.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter') {
          const blockId = (input as HTMLElement).dataset.imageQuery!;
          const btn = document.querySelector(`[data-search-image="${blockId}"]`) as HTMLButtonElement;
          btn?.click();
        }
      });
    });

    // Remove image from split block
    document.querySelectorAll('[data-remove-image]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const blockId = (btn as HTMLElement).dataset.removeImage!;
        if (!currentQuote) return;
        const block = currentQuote.blocks.find(b => b.id === blockId);
        if (block && block.type === 'split') {
          (block as any).imageUrl = '';
          render();
        }
      });
    });

    // Paste handler for split block images
    document.querySelectorAll('[data-paste-target]').forEach(area => {
      area.addEventListener('paste', async (e) => {
        const pasteEvent = e as ClipboardEvent;
        const blockId = (area as HTMLElement).dataset.pasteTarget!;
        if (!currentQuote) return;

        const items = pasteEvent.clipboardData?.items;
        if (!items) return;

        for (const item of items) {
          if (item.type.startsWith('image/')) {
            pasteEvent.preventDefault();
            const file = item.getAsFile();
            if (!file) return;

            try {
              // Compress image to max 800px width for reasonable file size
              const compressedBase64 = await compressImage(file, 800);

              const block = currentQuote.blocks.find(b => b.id === blockId);
              if (block && block.type === 'split') {
                (block as any).imageUrl = compressedBase64;
                render();
                showToast('Image added - click Save to keep it');
              }
            } catch (err) {
              console.error('Paste error:', err);
              showToast('Failed to paste image');
            }
            break;
          }
        }
      });

      // Visual feedback on focus
      area.addEventListener('focus', () => {
        const placeholder = area.querySelector('.upload-placeholder');
        placeholder?.classList.add('paste-active');
      });
      area.addEventListener('blur', () => {
        const placeholder = area.querySelector('.upload-placeholder');
        placeholder?.classList.remove('paste-active');
      });
    });

    // Slideshow listeners
    document.querySelector('[data-action="create-slideshow"]')?.addEventListener('click', () => {
      modalType = 'quote-picker';
      showModal = true;
      render();
    });

    document.querySelectorAll('[data-select-quote]').forEach(item => {
      item.addEventListener('click', async () => {
        const quoteId = (item as HTMLElement).dataset.selectQuote!;
        const quote = quotes.find(q => q.id === quoteId);
        if (!quote) return;

        // Close modal, show loading in main view
        showModal = false;
        creatingSlidesFromQuoteId = quoteId;
        view = 'slides';
        render();

        try {
          // Generate slides
          currentSlideshow = await generateSlideshow(quote);
          slideshows.unshift(currentSlideshow);
          await saveSlideshows();

          // Done - go to editor
          creatingSlidesFromQuoteId = '';
          currentSlideIndex = 0;
          view = 'slides-editor';
          showToast(`Created ${currentSlideshow.slides.length} slides from "${quote.title}"`);
        } catch (err) {
          console.error('Failed to create slides:', err);
          creatingSlidesFromQuoteId = '';
          showToast('Failed to create slides');
        }
        render();
      });
    });

    document.querySelectorAll('[data-edit-slideshow]').forEach(card => {
      card.addEventListener('click', () => {
        const id = (card as HTMLElement).dataset.editSlideshow!;
        currentSlideshow = JSON.parse(JSON.stringify(slideshows.find(p => p.id === id)));
        currentSlideIndex = 0;
        view = 'slides-editor';
        render();
      });
    });

    document.querySelector('[data-action="back-to-slides"]')?.addEventListener('click', () => {
      view = 'slides';
      currentSlideshow = null;
      render();
    });

    document.querySelector('[data-action="save-slideshow"]')?.addEventListener('click', async () => {
      if (!currentSlideshow) return;
      currentSlideshow.title = (document.getElementById('slideshow-title') as HTMLInputElement)?.value || currentSlideshow.title;
      currentSlideshow.updatedAt = Date.now();

      const idx = slideshows.findIndex(p => p.id === currentSlideshow!.id);
      if (idx >= 0) {
        slideshows[idx] = currentSlideshow;
      }
      await saveSlideshows();
      showToast('Slideshow saved!');
      render();
    });

    document.querySelector('[data-action="delete-slideshow"]')?.addEventListener('click', async () => {
      if (!currentSlideshow) return;
      if (!confirm('Delete these slides?')) return;
      slideshows = slideshows.filter(p => p.id !== currentSlideshow!.id);
      await saveSlideshows();
      currentSlideshow = null;
      view = 'slides';
      showToast('Slideshow deleted');
      render();
    });

    document.querySelectorAll('[data-select-slide]').forEach(thumb => {
      thumb.addEventListener('click', () => {
        currentSlideIndex = parseInt((thumb as HTMLElement).dataset.selectSlide!);
        render();
      });
    });

    document.querySelectorAll('[data-delete-slide]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        if (!currentSlideshow) return;
        const idx = parseInt((btn as HTMLElement).dataset.deleteSlide!);
        currentSlideshow.slides.splice(idx, 1);
        if (currentSlideIndex >= currentSlideshow.slides.length) {
          currentSlideIndex = Math.max(0, currentSlideshow.slides.length - 1);
        }
        render();
      });
    });

    document.querySelector('[data-action="add-slide"]')?.addEventListener('click', () => {
      if (!currentSlideshow) return;
      currentSlideshow.slides.push({
        id: genId(),
        type: 'content',
        headline: 'New Slide',
        bullets: ['Point 1', 'Point 2']
      });
      currentSlideIndex = currentSlideshow.slides.length - 1;
      render();
    });

    document.querySelectorAll('[data-slides-theme]').forEach(swatch => {
      swatch.addEventListener('click', () => {
        if (!currentSlideshow) return;
        currentSlideshow.theme = (swatch as HTMLElement).dataset.slidesTheme as SlideTheme;
        render();
      });
    });

    // Slide editor inputs
    document.querySelectorAll('[data-slide-field]').forEach(input => {
      input.addEventListener('input', () => {
        if (!currentSlideshow) return;
        const slide = currentSlideshow.slides[currentSlideIndex];
        const field = (input as HTMLElement).dataset.slideField!;
        if (field === 'headline') {
          slide.headline = (input as HTMLInputElement).value;
        } else if (field === 'subtitle') {
          if (!slide.bullets) slide.bullets = [];
          slide.bullets[0] = (input as HTMLInputElement).value;
        }
      });
    });

    document.querySelectorAll('[data-bullet-index]').forEach(input => {
      input.addEventListener('input', () => {
        if (!currentSlideshow) return;
        const slide = currentSlideshow.slides[currentSlideIndex];
        const idx = parseInt((input as HTMLElement).dataset.bulletIndex!);
        if (slide.bullets) {
          slide.bullets[idx] = (input as HTMLInputElement).value;
        }
      });
    });

    document.querySelectorAll('[data-delete-bullet]').forEach(btn => {
      btn.addEventListener('click', () => {
        if (!currentSlideshow) return;
        const slide = currentSlideshow.slides[currentSlideIndex];
        const idx = parseInt((btn as HTMLElement).dataset.deleteBullet!);
        if (slide.bullets) {
          slide.bullets.splice(idx, 1);
          render();
        }
      });
    });

    document.querySelector('[data-action="add-bullet"]')?.addEventListener('click', () => {
      if (!currentSlideshow) return;
      const slide = currentSlideshow.slides[currentSlideIndex];
      if (!slide.bullets) slide.bullets = [];
      slide.bullets.push('New point');
      render();
    });

    document.querySelectorAll('[data-stat-index]').forEach(input => {
      input.addEventListener('input', () => {
        if (!currentSlideshow) return;
        const slide = currentSlideshow.slides[currentSlideIndex];
        const idx = parseInt((input as HTMLElement).dataset.statIndex!);
        const field = (input as HTMLElement).dataset.statField!;
        if (slide.stats && slide.stats[idx]) {
          (slide.stats[idx] as any)[field] = (input as HTMLInputElement).value;
        }
      });
    });

    document.getElementById('slide-type-select')?.addEventListener('change', (e) => {
      if (!currentSlideshow) return;
      const slide = currentSlideshow.slides[currentSlideIndex];
      const newType = (e.target as HTMLSelectElement).value as Slide['type'];
      slide.type = newType;
      // Initialize defaults for new type
      if (newType === 'content' && !slide.bullets) slide.bullets = ['Point 1'];
      if (newType === 'data' && !slide.stats) slide.stats = [{ label: 'Label', value: '0' }];
      render();
    });

    // Slideshow controls
    document.querySelector('[data-action="start-slideshow"]')?.addEventListener('click', () => {
      currentSlideIndex = 0;
      view = 'slides-view';
      render();
    });

    document.querySelector('[data-action="exit-slideshow"]')?.addEventListener('click', () => {
      view = 'slides-editor';
      render();
    });

    document.querySelector('[data-action="prev-slide"]')?.addEventListener('click', () => {
      if (currentSlideIndex > 0) {
        currentSlideIndex--;
        render();
      }
    });

    document.querySelector('[data-action="next-slide"]')?.addEventListener('click', () => {
      if (currentSlideshow && currentSlideIndex < currentSlideshow.slides.length - 1) {
        currentSlideIndex++;
        render();
      }
    });

    // Keyboard navigation for slideshow
    if (view === 'slides-view') {
      const handleKeydown = (e: KeyboardEvent) => {
        if (e.key === 'ArrowRight' || e.key === ' ') {
          if (currentSlideshow && currentSlideIndex < currentSlideshow.slides.length - 1) {
            currentSlideIndex++;
            render();
          }
        } else if (e.key === 'ArrowLeft') {
          if (currentSlideIndex > 0) {
            currentSlideIndex--;
            render();
          }
        } else if (e.key === 'Escape') {
          view = 'slides-editor';
          render();
        }
      };
      document.addEventListener('keydown', handleKeydown);
    }

    // Assets listeners
    document.querySelector('[data-action="add-asset"]')?.addEventListener('click', () => {
      showAssetUpload = true;
      render();
    });

    document.querySelector('[data-action="close-asset-upload"]')?.addEventListener('click', () => {
      showAssetUpload = false;
      render();
    });

    document.querySelectorAll('[data-asset-tab]').forEach(tab => {
      tab.addEventListener('click', () => {
        const tabType = (tab as HTMLElement).dataset.assetTab;
        document.querySelectorAll('.asset-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const dropzone = document.querySelector('.asset-upload-dropzone') as HTMLElement;
        const urlForm = document.querySelector('.asset-url-form') as HTMLElement;
        if (tabType === 'upload') {
          dropzone.style.display = 'block';
          urlForm.style.display = 'none';
        } else {
          dropzone.style.display = 'none';
          urlForm.style.display = 'block';
        }
      });
    });

    document.querySelectorAll('[data-asset-filter]').forEach(btn => {
      btn.addEventListener('click', () => {
        assetFilter = (btn as HTMLElement).dataset.assetFilter as typeof assetFilter;
        render();
      });
    });

    document.getElementById('asset-search')?.addEventListener('input', (e) => {
      assetSearch = (e.target as HTMLInputElement).value;
      render();
    });

    // File upload
    const fileInput = document.getElementById('asset-file-input') as HTMLInputElement;
    if (fileInput) {
      fileInput.addEventListener('change', async () => {
        const fileList = fileInput.files;
        if (!fileList || fileList.length === 0) return;

        // Copy files to array BEFORE any render() calls
        const filesToProcess: File[] = Array.from(fileList);

        // Show processing modal
        processingAssetsCount = filesToProcess.length;
        processingAssets = true;
        showAssetUpload = false;
        render();

        // Small delay to ensure modal renders
        await new Promise(r => setTimeout(r, 50));

        try {
          let added = 0;
          for (const file of filesToProcess) {
            try {
              const asset = await createAssetFromImage(file);
              assets.unshift(asset);
              added++;
            } catch (err) {
              console.error('Failed to create asset:', err);
            }
          }
          await saveAssets();
          processingAssets = false;
          showToast(`Added ${added} asset${added !== 1 ? 's' : ''}`);
          render();
        } catch (err) {
          console.error('Upload error:', err);
          processingAssets = false;
          showToast(`Upload failed: ${(err as Error).message}`);
          render();
        }
      });
    }

    // Dropzone
    const dropzone = document.querySelector('[data-asset-dropzone]');
    if (dropzone) {
      dropzone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropzone.classList.add('dragover');
      });
      dropzone.addEventListener('dragleave', () => {
        dropzone.classList.remove('dragover');
      });
      dropzone.addEventListener('drop', async (e) => {
        e.preventDefault();
        dropzone.classList.remove('dragover');
        const fileList = (e as DragEvent).dataTransfer?.files;
        if (!fileList || fileList.length === 0) return;

        // Copy and filter to images only
        const filesToProcess = Array.from(fileList).filter(f => f.type.startsWith('image/'));
        if (filesToProcess.length === 0) return;

        // Show processing modal
        processingAssetsCount = filesToProcess.length;
        processingAssets = true;
        showAssetUpload = false;
        render();

        await new Promise(r => setTimeout(r, 50));

        try {
          let added = 0;
          for (const file of filesToProcess) {
            try {
              const asset = await createAssetFromImage(file);
              assets.unshift(asset);
              added++;
            } catch (err) {
              console.error('Failed to create asset:', err);
            }
          }
          await saveAssets();
          processingAssets = false;
          showToast(`Added ${added} asset${added !== 1 ? 's' : ''}`);
          render();
        } catch (err) {
          console.error('Drop upload error:', err);
          processingAssets = false;
          showToast(`Upload failed`);
          render();
        }
      });
      dropzone.addEventListener('click', () => {
        document.getElementById('asset-file-input')?.click();
      });
    }

    // URL asset
    document.querySelector('[data-action="save-url-asset"]')?.addEventListener('click', async () => {
      const urlInput = document.getElementById('asset-url-input') as HTMLInputElement;
      const nameInput = document.getElementById('asset-name-input') as HTMLInputElement;
      const url = urlInput?.value?.trim();
      if (!url) return;

      try {
        const asset = await createAssetFromUrl(url, nameInput?.value?.trim());
        assets.unshift(asset);
        await saveAssets();
        showAssetUpload = false;
        showToast(`Added ${asset.name}`);
        render();
      } catch (err) {
        showToast('Failed to add URL');
      }
    });

    // Delete asset
    document.querySelectorAll('[data-delete-asset]').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const id = (btn as HTMLElement).dataset.deleteAsset!;
        if (!confirm('Delete this asset?')) return;
        assets = assets.filter(a => a.id !== id);
        await saveAssets();
        showToast('Asset deleted');
        render();
      });
    });

    // Copy asset
    document.querySelectorAll('[data-copy-asset]').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const id = (btn as HTMLElement).dataset.copyAsset!;
        const asset = assets.find(a => a.id === id);
        if (asset?.imageData) {
          await navigator.clipboard.writeText(asset.imageData);
          showToast('Image copied to clipboard');
        } else if (asset?.url) {
          await navigator.clipboard.writeText(asset.url);
          showToast('URL copied to clipboard');
        }
      });
    });
  }

  loadQuotes();
  loadSlides();
  loadAssets();
</script>
