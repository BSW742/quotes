      thumbnail: '',
      blocks: [
        { id: 'hero', type: 'hero', title: 'Consulting Engagement', subtitle: 'Strategic Advisory for [Client Name]' },
        { id: 'about', type: 'section', title: 'About Bridge Point', content: `Bridge Point provides strategic technology consulting to organisations ready to modernize their operations.

