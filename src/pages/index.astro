              ${currentSlideshow.slides.map((slide, i) => `
                <div class="slide-thumb ${i === currentSlideIndex ? 'active' : ''}" data-select-slide="${i}">
                  <div class="slide-thumb-number">${i + 1}</div>
                  <div class="slide-thumb-content">
                    <div class="slide-thumb-type">${slide.type}</div>
                    <div class="slide-thumb-headline">${slide.headline || '(empty)'}</div>
                  </div>
                  <button class="slide-thumb-delete" data-delete-slide="${i}">${icons.x}</button>
                </div>
              `).join('')}
            </div>
            <button class="add-item-btn" data-action="add-slide">+ Add Slide</button>
          </div>
          <div class="editor-panel">
            <div class="panel-title">Details</div>
            <div class="form-group">
              <label class="form-label">Title</label>
              <input class="form-input" type="text" id="slideshow-title" value="${currentSlideshow.title}">
            </div>
            ${currentSlideshow.clientName ? `<div class="form-group"><label class="form-label">Client</label><div style="color:var(--text)">${currentSlideshow.clientName}</div></div>` : ''}
          </div>
        </div>
        <div class="slides-main">
          <div class="slides-top-toolbar">
            <div class="slides-theme-bar">
              <span class="toolbar-label">Theme:</span>
              <select class="toolbar-select" id="slide-theme-select">
                <option value="dark" ${(currentSlideshow.slides[currentSlideIndex]?.theme || 'dark') === 'dark' ? 'selected' : ''}>Dark</option>
                <option value="light" ${currentSlideshow.slides[currentSlideIndex]?.theme === 'light' ? 'selected' : ''}>Light</option>
                <option value="gradient" ${currentSlideshow.slides[currentSlideIndex]?.theme === 'gradient' ? 'selected' : ''}>Gradient</option>
                <option value="minimal" ${currentSlideshow.slides[currentSlideIndex]?.theme === 'minimal' ? 'selected' : ''}>Minimal</option>
                <option value="bold" ${currentSlideshow.slides[currentSlideIndex]?.theme === 'bold' ? 'selected' : ''}>Bold</option>
                ${currentSlideshow.brandColor ? `<option value="brand" ${currentSlideshow.slides[currentSlideIndex]?.theme === 'brand' ? 'selected' : ''}>Brand</option>` : ''}
              </select>
            </div>
            <div class="slides-layout-bar">
              <span class="toolbar-label">Layout:</span>
              <div class="slides-layout-btn ${(currentSlideshow.slides[currentSlideIndex]?.layout || 'default') === 'default' ? 'active' : ''}" data-slide-layout="default" title="Default">
                <svg width="20" height="14" viewBox="0 0 20 14"><rect x="1" y="1" width="18" height="12" rx="1" fill="none" stroke="currentColor" stroke-width="1.5"/><line x1="4" y1="4" x2="16" y2="4" stroke="currentColor" stroke-width="1.5"/><line x1="4" y1="7" x2="12" y2="7" stroke="currentColor" stroke-width="1"/><line x1="4" y1="10" x2="10" y2="10" stroke="currentColor" stroke-width="1"/></svg>
              </div>
              <div class="slides-layout-btn ${currentSlideshow.slides[currentSlideIndex]?.layout === 'split' ? 'active' : ''}" data-slide-layout="split" title="Text + Image">
                <svg width="20" height="14" viewBox="0 0 20 14"><rect x="1" y="1" width="18" height="12" rx="1" fill="none" stroke="currentColor" stroke-width="1.5"/><line x1="10" y1="1" x2="10" y2="13" stroke="currentColor" stroke-width="1"/><line x1="3" y1="4" x2="8" y2="4" stroke="currentColor" stroke-width="1"/><line x1="3" y1="7" x2="7" y2="7" stroke="currentColor" stroke-width="1"/><rect x="12" y="3" width="5" height="8" rx="0.5" fill="currentColor" opacity="0.3"/></svg>
              </div>
            </div>
            <div class="slides-logo-toggle">
              <label class="toggle-switch">
                <input type="checkbox" id="slide-logos-toggle" ${currentSlideshow.slides[currentSlideIndex]?.showLogos !== false ? 'checked' : ''}>
                <span class="toggle-slider"></span>
              </label>
              <span class="toolbar-label">Logos</span>
              <img src="${BRIDGEPOINT_LOGO_WHITE}" alt="Bridge Point" class="toolbar-logo-mini">
              ${currentSlideshow.clientLogo ? `<img src="${currentSlideshow.clientLogo}" alt="" class="toolbar-logo-mini">` : ''}
            </div>
          </div>
          ${renderSlideEditor()}
        </div>
      </div>
    `;
  }

  function renderSlideEditor(): string {
    if (!currentSlideshow || currentSlideIndex >= currentSlideshow.slides.length) return '';
    const slide = currentSlideshow.slides[currentSlideIndex];

    const isSplit = slide.layout === 'split';

    return `
      <div class="slide-editor-preview theme-${slide.theme || 'dark'}">
        <div class="slide-content slide-type-${slide.type} ${isSplit ? 'layout-split' : ''}">
          ${isSplit ? '<div class="slide-split-left">' : ''}
          ${slide.type === 'title' ? `
            <input class="slide-headline-input" type="text" value="${slide.headline || ''}" data-slide-field="headline" placeholder="Headline">
            <input class="slide-subtitle-input" type="text" value="${slide.bullets?.[0] || ''}" data-slide-field="subtitle" placeholder="Subtitle">
          ` : ''}
          ${slide.type === 'content' ? `
            <input class="slide-headline-input" type="text" value="${slide.headline || ''}" data-slide-field="headline" placeholder="Headline">
            <div class="slide-bullets-editor">
              ${(slide.bullets || []).map((b, i) => `
                <div class="slide-bullet-row">
                  <span class="slide-bullet-dot">•</span>
                  <input class="slide-bullet-input" type="text" value="${b}" data-bullet-index="${i}" placeholder="Bullet point">
                  <button class="slide-bullet-delete" data-delete-bullet="${i}">${icons.x}</button>
                </div>
              `).join('')}
              <button class="add-item-btn" data-action="add-bullet">+ Add Point</button>
            </div>
          ` : ''}
          ${slide.type === 'visual' && !isSplit ? `
            <input class="slide-headline-input" type="text" value="${slide.headline || ''}" data-slide-field="headline" placeholder="Headline">
            <div class="slide-visual-area">
              ${slide.image ? `<img src="${slide.image}" class="slide-visual-image">` : '<div class="slide-visual-placeholder">No image</div>'}
            </div>
          ` : ''}
          ${slide.type === 'visual' && isSplit ? `
            <input class="slide-headline-input" type="text" value="${slide.headline || ''}" data-slide-field="headline" placeholder="Headline">
            <textarea class="slide-caption-input" data-slide-field="caption" placeholder="Add description text...">${slide.bullets?.[0] || ''}</textarea>
          ` : ''}
          ${slide.type === 'data' ? `
            <input class="slide-headline-input" type="text" value="${slide.headline || ''}" data-slide-field="headline" placeholder="Headline">
            <div class="slide-stats-grid">
              ${(slide.stats || []).map((s, i) => `
                <div class="slide-stat-item">
                  <input class="slide-stat-value" type="text" value="${s.value}" data-stat-index="${i}" data-stat-field="value" placeholder="Value">
                  <input class="slide-stat-label" type="text" value="${s.label}" data-stat-index="${i}" data-stat-field="label" placeholder="Label">
                </div>
              `).join('')}
            </div>
          ` : ''}
          ${slide.type === 'break' ? `
            <div class="slide-break-visual">
              <div class="slide-break-line"></div>
            </div>
          ` : ''}
          ${isSplit ? '</div>' : ''}
          ${isSplit ? `
            <div class="slide-split-right">
              <div class="slide-split-image-area">
                ${slide.image ? `
                  <img src="${slide.image}" class="slide-split-image">
                  <button class="slide-image-change" data-action="pick-slide-image">${icons.image} Change</button>
                ` : `
                  <div class="slide-image-placeholder">
                    <button class="slide-image-upload-btn" data-action="pick-slide-image">${icons.image} Add from Assets</button>
                  </div>
                `}
              </div>
            </div>
          ` : ''}
        </div>
      </div>
      <div class="slide-type-picker">
        <label class="form-label">Slide Type</label>
        <select class="form-input" id="slide-type-select">
          <option value="title" ${slide.type === 'title' ? 'selected' : ''}>Title</option>
          <option value="content" ${slide.type === 'content' ? 'selected' : ''}>Content</option>
          <option value="visual" ${slide.type === 'visual' ? 'selected' : ''}>Visual</option>
          <option value="data" ${slide.type === 'data' ? 'selected' : ''}>Data</option>
          <option value="break" ${slide.type === 'break' ? 'selected' : ''}>Break</option>
        </select>
      </div>
    `;
  }

