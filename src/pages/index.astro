  async function createAssetFromUrl(url: string, name?: string): Promise<Asset> {
    const brandColor = await extractBrandColor(url);
    const clientName = name || new URL(url).hostname.replace('www.', '').split('.')[0];

    const asset: Asset = {
      id: genId(),
      type: 'url',
      name: clientName.charAt(0).toUpperCase() + clientName.slice(1),
      url,
      brandColor: brandColor || undefined,
      tags: ['website'],
      createdAt: Date.now(),
      updatedAt: Date.now()
    };

    return asset;
  }

  async function createAssetFromImage(file: File, name?: string): Promise<Asset> {
    const base64 = await new Promise<string>((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve(reader.result as string);
      reader.onerror = () => reject(new Error('Failed to read file'));
      reader.readAsDataURL(file);
    });

    // Create thumbnail (smaller version)
    const thumbnail = await compressImage(file, 200);

    const asset: Asset = {
      id: genId(),
      type: file.name.toLowerCase().includes('logo') ? 'logo' : 'image',
      name: name || file.name.replace(/\.[^/.]+$/, ''),
      imageData: base64,
      thumbnail,
      tags: [],
      createdAt: Date.now(),
      updatedAt: Date.now()
    };

    return asset;
  }

  // Extract brand color from website (with 3s timeout)
  async function extractBrandColor(websiteUrl: string): Promise<string | null> {
    if (!websiteUrl) return null;
    try {
      const controller = new AbortController();
      const timeout = setTimeout(() => controller.abort(), 3000);
      const response = await fetch(`${WORKER_URL}/extract-brand?url=${encodeURIComponent(websiteUrl)}`, {
        signal: controller.signal
      });
      clearTimeout(timeout);
      if (response.ok) {
        const data = await response.json();
        return data.color || null;
      }
    } catch (e) {
      console.warn('Failed to extract brand color:', e);
    }
    return null;
  }

  async function generateSlideshow(quote: Quote): Promise<Slideshow> {
    const slides: Slide[] = [];

    // Try to extract brand color from client website
    let brandColor: string | undefined;
    if (quote.clientWebsite) {
      const color = await extractBrandColor(quote.clientWebsite);
      if (color) brandColor = color;
    }

    quote.blocks.forEach(block => {
      switch (block.type) {
        case 'hero':
          slides.push({
            id: genId(),
            type: 'title',
            headline: block.title,
            bullets: block.subtitle ? [block.subtitle] : []
          });
          break;
        case 'section':
          // Extract bullet points from content
          const lines = block.content.split('\n').filter(l => l.trim());
          const bullets = lines
            .filter(l => l.trim().startsWith('•') || l.trim().startsWith('-') || l.trim().startsWith('*'))
            .map(l => l.replace(/^[\s•\-*]+/, '').trim())
            .slice(0, 4);
          slides.push({
            id: genId(),
            type: 'content',
            headline: block.title,
            bullets: bullets.length > 0 ? bullets : lines.slice(0, 3)
          });
          break;
        case 'split':
          slides.push({
            id: genId(),
            type: 'visual',
            headline: block.title,
            image: block.imageUrl,
            bullets: block.content ? [block.content.split('\n')[0]] : []
          });
          break;
        case 'pricing':
          const total = block.items.reduce((sum, i) => i.selected ? sum + (i.quantity * i.unitPrice) : sum, 0);
          const itemCount = block.items.filter(i => i.selected).length;
          slides.push({
            id: genId(),
            type: 'data',
            headline: block.title,
            stats: [
              { label: 'Total Investment', value: formatCurrency(total) },
              { label: 'Items Included', value: String(itemCount) },
            ]
          });
          break;
        case 'divider':
          slides.push({
            id: genId(),
            type: 'break',
            headline: ''
          });
          break;
        // Skip accept blocks
      }
    });

    return {
      id: genId(),
      title: quote.title,
      sourceQuoteId: quote.id,
      theme: brandColor ? 'brand' : 'dark',
      brandColor,
      clientName: quote.clientName,
      clientLogo: quote.clientLogo,
      clientWebsite: quote.clientWebsite,
      createdAt: Date.now(),
      updatedAt: Date.now(),
      slides
    };
  }

  function genId(): string {
    return Math.random().toString(36).substring(2, 10);
  }

  // Global handler for asset file upload (called via inline onchange)
  (window as any).handleAssetFiles = async function(input: HTMLInputElement) {
    const fileList = input.files;
    if (!fileList || fileList.length === 0) return;

    // Copy files to array BEFORE any render
    const filesToProcess: File[] = Array.from(fileList);

    // Show processing modal
    processingAssetsCount = filesToProcess.length;
    processingAssets = true;
    showAssetUpload = false;
    render();

    await new Promise(r => setTimeout(r, 50));

    try {
      let added = 0;
      for (const file of filesToProcess) {
        try {
          const asset = await createAssetFromImage(file);
          assets.unshift(asset);
          added++;
        } catch (err) {
          console.error('Failed to create asset:', err);
        }
      }
      await saveAssets();
      processingAssets = false;
      input.value = '';
      showToast(`Added ${added} asset${added !== 1 ? 's' : ''}`);
      render();
    } catch (err) {
      console.error('Upload error:', err);
      processingAssets = false;
      showToast(`Upload failed`);
      render();
    }
  };

  function formatCurrency(amount: number, currency = 'NZD'): string {
    return new Intl.NumberFormat('en-NZ', { style: 'currency', currency }).format(amount);
  }

  function calcTotal(blocks: Block[]): number {
    let total = 0;
    blocks.forEach(b => {
      if (b.type === 'pricing') {
        b.items.forEach(item => {
          if (item.selected) total += item.quantity * item.unitPrice;
        });
      }
    });
    return total;
  }

  function formatDate(ts: number): string {
    return new Date(ts).toLocaleDateString('en-NZ', { day: 'numeric', month: 'short', year: 'numeric' });
  }

  // Compress image to reduce storage size
  function compressImage(file: File, maxWidth: number): Promise<string> {
    return new Promise((resolve, reject) => {
      const img = new Image();
      const canvas = document.createElement('canvas');
      const ctx = canvas.getContext('2d');

      img.onload = () => {
        let { width, height } = img;
        if (width > maxWidth) {
          height = (height * maxWidth) / width;
          width = maxWidth;
        }
        canvas.width = width;
        canvas.height = height;
        ctx?.drawImage(img, 0, 0, width, height);
        resolve(canvas.toDataURL('image/jpeg', 0.8));
      };

      img.onerror = () => reject(new Error('Failed to load image'));
      img.src = URL.createObjectURL(file);
    });
  }

