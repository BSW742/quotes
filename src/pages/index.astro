  async function createAssetFromUrl(url: string, name?: string): Promise<Asset> {
    const brandColor = await extractBrandColor(url);
    const clientName = name || new URL(url).hostname.replace('www.', '').split('.')[0];

    const asset: Asset = {
      id: genId(),
      type: 'url',
      name: clientName.charAt(0).toUpperCase() + clientName.slice(1),
      url,
      brandColor: brandColor || undefined,
      tags: ['website'],
      createdAt: Date.now(),
      updatedAt: Date.now()
    };

    return asset;
  }

  async function createAssetFromImage(file: File, name?: string): Promise<Asset> {
    const base64 = await new Promise<string>((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve(reader.result as string);
      reader.onerror = () => reject(new Error('Failed to read file'));
      reader.readAsDataURL(file);
    });

    // Create thumbnail (smaller version)
    const thumbnail = await compressImage(file, 200);

    const asset: Asset = {
      id: genId(),
      type: file.name.toLowerCase().includes('logo') ? 'logo' : 'image',
      name: name || file.name.replace(/\.[^/.]+$/, ''),
      imageData: base64,
      thumbnail,
      tags: [],
      createdAt: Date.now(),
      updatedAt: Date.now()
    };

    return asset;
  }

  // Extract brand color from website (with 3s timeout)
  async function extractBrandColor(websiteUrl: string): Promise<string | null> {
    if (!websiteUrl) return null;
    try {
      const controller = new AbortController();
      const timeout = setTimeout(() => controller.abort(), 3000);
      const response = await fetch(`${WORKER_URL}/extract-brand?url=${encodeURIComponent(websiteUrl)}`, {
        signal: controller.signal
      });
      clearTimeout(timeout);
      if (response.ok) {
        const data = await response.json();
        return data.color || null;
      }
    } catch (e) {
      console.warn('Failed to extract brand color:', e);
    }
    return null;
  }

  async function generateSlideshow(quote: Quote): Promise<Slideshow> {
    const slides: Slide[] = [];

    // Try to extract brand color from client website
    let brandColor: string | undefined;
    if (quote.clientWebsite) {
      const color = await extractBrandColor(quote.clientWebsite);
      if (color) brandColor = color;
    }

    quote.blocks.forEach(block => {
      switch (block.type) {
        case 'hero':
          slides.push({
            id: genId(),
            type: 'title',
            headline: block.title,
            bullets: block.subtitle ? [block.subtitle] : []
          });
          break;
        case 'section':
          // Extract bullet points from content
          const lines = block.content.split('\n').filter(l => l.trim());
          const bullets = lines
            .filter(l => l.trim().startsWith('•') || l.trim().startsWith('-') || l.trim().startsWith('*'))
            .map(l => l.replace(/^[\s•\-*]+/, '').trim())
            .slice(0, 4);
          slides.push({
            id: genId(),
            type: 'content',
            headline: block.title,
            bullets: bullets.length > 0 ? bullets : lines.slice(0, 3)
          });
          break;
        case 'split':
          slides.push({
            id: genId(),
            type: 'visual',
            headline: block.title,
            image: block.imageUrl,
            bullets: block.content ? [block.content.split('\n')[0]] : []
          });
          break;
        case 'pricing':
          const total = block.items.reduce((sum, i) => i.selected ? sum + (i.quantity * i.unitPrice) : sum, 0);
          const itemCount = block.items.filter(i => i.selected).length;
          slides.push({
            id: genId(),
            type: 'data',
            headline: block.title,
            stats: [
              { label: 'Total Investment', value: formatCurrency(total) },
              { label: 'Items Included', value: String(itemCount) },
            ]
          });
          break;
        case 'divider':
          slides.push({
            id: genId(),
            type: 'break',
            headline: ''
          });
          break;
        // Skip accept blocks
      }
    });

    return {
      id: genId(),
      title: quote.title,
      sourceQuoteId: quote.id,
      theme: brandColor ? 'brand' : 'dark',
      brandColor,
      clientName: quote.clientName,
      clientLogo: quote.clientLogo,
      clientWebsite: quote.clientWebsite,
      createdAt: Date.now(),
      updatedAt: Date.now(),
      slides
    };
  }

