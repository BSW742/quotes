    const body = `Hi ${currentQuote.clientName || 'there'},

Thank you for your interest in working with Bridge Point. I've prepared a proposal for you.

Proposal Total: ${formatCurrency(currentQuote.total, currentQuote.currency)}

View your proposal here:
${quoteUrl}

If you have any questions, feel free to reply to this email.

Best regards,
Ben Wilson
Bridge Point`;

    const mailtoUrl = `mailto:${currentQuote.clientEmail}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    window.open(mailtoUrl, '_blank');

    // Update status
    currentQuote.status = 'sent';
    const idx = quotes.findIndex(q => q.id === currentQuote!.id);
    if (idx >= 0) quotes[idx] = currentQuote;
    await saveQuotes();

    showToast('Email draft opened!');
    showModal = false;
    render();
