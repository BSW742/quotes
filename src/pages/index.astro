  .slide-thumb-headline { font-size: 0.8rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .slide-thumb-delete {
    position: absolute; right: 8px; top: 50%; transform: translateY(-50%);
    background: none; border: none; color: var(--text-muted); cursor: pointer;
    opacity: 0; transition: opacity 0.2s;
  }
  .slide-thumb:hover .slide-thumb-delete { opacity: 1; }
  .slide-thumb-delete:hover { color: #ff4444; }
  .slide-thumb-delete svg { width: 14px; height: 14px; }

  .slides-theme-swatches { display: flex; flex-wrap: wrap; gap: 8px; }
  .slides-theme-swatch {
    padding: 8px 12px; background: var(--bg); border: 1px solid var(--border);
    border-radius: 6px; font-size: 0.8rem; cursor: pointer; transition: all 0.2s;
  }
  .slides-theme-swatch:hover { border-color: var(--cyan); }
  .slides-theme-swatch.active { border-color: var(--cyan); background: var(--bg-hover); color: var(--cyan); }

  .slides-logos { display: flex; flex-direction: column; gap: 12px; }
  .slides-logo-item {
    display: flex; align-items: center; gap: 10px;
    padding: 10px; background: var(--bg); border-radius: 8px;
  }
  .slides-logo { height: 24px; width: auto; max-width: 80px; object-fit: contain; }
  .slides-logo-item span { font-size: 0.8rem; color: var(--text-muted); }

  .slide-editor-preview {
    aspect-ratio: 16/9; border-radius: 12px; overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    padding: 40px; margin-bottom: 20px;
  }
  .slide-editor-preview.theme-dark { background: #0a0a0f; color: #fff; }
  .slide-editor-preview.theme-light { background: #fafafa; color: #1a1a1a; }
  .slide-editor-preview.theme-gradient { background: linear-gradient(135deg, #00d4ff, #7b2fff, #ff006e); color: #fff; }
  .slide-editor-preview.theme-minimal { background: #fff; color: #333; font-family: Georgia, serif; }
  .slide-editor-preview.theme-bold { background: #000; color: #fff; font-size: 120%; font-weight: 800; }

  .slide-content { width: 100%; max-width: 800px; text-align: center; }
  .slide-content.layout-split {
    display: grid; grid-template-columns: 1fr 1fr; gap: 32px;
    max-width: 100%; text-align: left;
  }
  .slide-split-left { display: flex; flex-direction: column; justify-content: center; }
  .slide-split-left .slide-headline-input { text-align: left; font-size: 1.75rem; }
  .slide-split-right { display: flex; align-items: center; justify-content: center; }
  .slide-split-image-area {
    width: 100%; aspect-ratio: 4/3; border-radius: 12px; overflow: hidden;
    background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center;
  }
  .slide-split-image { width: 100%; height: 100%; object-fit: cover; }
  .slide-image-change {
    position: absolute; bottom: 12px; right: 12px;
