  async function loadQuotes() {
    // Load from localStorage first (instant, prevents data loss during dev)
    const localData = localStorage.getItem(LOCAL_STORAGE_KEY);
    if (localData) {
      try {
        const parsed = JSON.parse(localData);
        if (parsed?.quotes) {
          quotes = parsed.quotes;
          loading = false;
          render();
        }
      } catch (e) {
        console.warn('Failed to parse local backup:', e);
      }
    }

    // Then sync with R2 (source of truth)
    try {
      const data = await loadFromR2<{ quotes: Quote[] }>('quotes-data.json');
      if (data?.quotes) {
        // Merge: keep local quotes that aren't in R2, add R2 quotes
        const r2Ids = new Set(data.quotes.map(q => q.id));
        const localOnly = quotes.filter(q => !r2Ids.has(q.id));
        quotes = [...data.quotes, ...localOnly];
        // Save merged data back
        if (localOnly.length > 0) {
          await saveQuotes();
        }
        localStorage.setItem(LOCAL_STORAGE_KEY, JSON.stringify({ quotes }));
      }
    } catch (e) {
      console.warn('Failed to load from R2, using local backup:', e);
    }

    loading = false;
    render();
  }

  async function saveQuotes() {
    // Save to localStorage immediately (backup)
    localStorage.setItem(LOCAL_STORAGE_KEY, JSON.stringify({ quotes }));
    // Then save to R2
    await saveToR2('quotes-data.json', { quotes });
  }

