        { id: 'accept', type: 'accept', buttonText: 'Approve Project', terms: 'Acceptance authorizes Bridge Point to commence work. Deposit invoice follows.' }
      ]
    },
    {
      id: 'consulting',
      name: 'Consulting Engagement',
      description: 'Advisory and strategy services',
