  .theme-light .slide-headline-input:focus, .theme-minimal .slide-headline-input:focus { border-color: var(--purple); }

  .slide-subtitle-input {
    width: 100%; background: transparent; border: none; border-bottom: 1px dashed rgba(255,255,255,0.2);
    color: inherit; font-size: 1.2rem; text-align: center; padding: 8px; opacity: 0.8;
  }
  .slide-subtitle-input:focus { outline: none; border-color: var(--cyan); }
  .theme-light .slide-subtitle-input, .theme-minimal .slide-subtitle-input { border-color: rgba(0,0,0,0.1); }

  .slide-bullets-editor { text-align: left; margin-top: 20px; }
  .slide-bullet-row { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
  .slide-bullet-dot { font-size: 1.5rem; color: var(--cyan); }
  .slide-bullet-input {
    flex: 1; background: transparent; border: none; border-bottom: 1px dashed rgba(255,255,255,0.2);
    color: inherit; font-size: 1.1rem; padding: 6px;
  }
  .slide-bullet-input:focus { outline: none; border-color: var(--cyan); }
