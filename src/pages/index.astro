  // Global handler for asset file upload (called via inline onchange)
  (window as any).handleAssetFiles = async function(input: HTMLInputElement) {
    const fileList = input.files;
    if (!fileList || fileList.length === 0) return;

    // Copy files to array BEFORE any render
    const filesToProcess: File[] = Array.from(fileList);

    // Show processing modal
    processingAssetsCount = filesToProcess.length;
    processingAssets = true;
    showAssetUpload = false;
    render();

    await new Promise(r => setTimeout(r, 50));

    try {
      let added = 0;
      for (const file of filesToProcess) {
        try {
          const asset = await createAssetFromImage(file);
          assets.unshift(asset);
          added++;
        } catch (err) {
          console.error('Failed to create asset:', err);
        }
      }
      await saveAssets();
      processingAssets = false;
      input.value = '';
      showToast(`Added ${added} asset${added !== 1 ? 's' : ''}`);
      render();
    } catch (err) {
      console.error('Upload error:', err);
      processingAssets = false;
      showToast(`Upload failed`);
      render();
    }
  };

  function formatCurrency(amount: number, currency = 'NZD'): string {
    return new Intl.NumberFormat('en-NZ', { style: 'currency', currency }).format(amount);
  }

  function calcTotal(blocks: Block[]): number {
    let total = 0;
    blocks.forEach(b => {
      if (b.type === 'pricing') {
        b.items.forEach(item => {
          if (item.selected) total += item.quantity * item.unitPrice;
        });
      }
    });
    return total;
  }

  function formatDate(ts: number): string {
    return new Date(ts).toLocaleDateString('en-NZ', { day: 'numeric', month: 'short', year: 'numeric' });
  }

  // Compress image to reduce storage size
  function compressImage(file: File, maxWidth: number): Promise<string> {
    return new Promise((resolve, reject) => {
      const img = new Image();
      const canvas = document.createElement('canvas');
      const ctx = canvas.getContext('2d');

      img.onload = () => {
        let { width, height } = img;
        if (width > maxWidth) {
          height = (height * maxWidth) / width;
          width = maxWidth;
        }
        canvas.width = width;
        canvas.height = height;
        ctx?.drawImage(img, 0, 0, width, height);
        resolve(canvas.toDataURL('image/jpeg', 0.8));
      };

      img.onerror = () => reject(new Error('Failed to load image'));
      img.src = URL.createObjectURL(file);
    });
  }

  // IndexedDB for narration video storage
  async function initNarrationDB(): Promise<IDBDatabase> {
    if (narrationDB) return narrationDB;
    return new Promise((resolve, reject) => {
      const request = indexedDB.open(NARRATION_DB_NAME, 1);
      request.onerror = () => reject(request.error);
      request.onsuccess = () => {
        narrationDB = request.result;
        resolve(narrationDB);
      };
      request.onupgradeneeded = (e) => {
        const database = (e.target as IDBOpenDBRequest).result;
        if (!database.objectStoreNames.contains(NARRATION_DB_STORE)) {
          database.createObjectStore(NARRATION_DB_STORE);
        }
      };
    });
  }

  async function saveNarrationToDB(slideshowId: string, blob: Blob): Promise<void> {
    const database = await initNarrationDB();
    return new Promise((resolve, reject) => {
      const tx = database.transaction(NARRATION_DB_STORE, 'readwrite');
      const store = tx.objectStore(NARRATION_DB_STORE);
      const request = store.put(blob, slideshowId);
      request.onsuccess = () => resolve();
      request.onerror = () => reject(request.error);
    });
  }

  async function getNarrationFromDB(slideshowId: string): Promise<Blob | null> {
    const database = await initNarrationDB();
    return new Promise((resolve, reject) => {
      const tx = database.transaction(NARRATION_DB_STORE, 'readonly');
      const store = tx.objectStore(NARRATION_DB_STORE);
      const request = store.get(slideshowId);
      request.onsuccess = () => resolve(request.result || null);
      request.onerror = () => reject(request.error);
    });
  }

  async function deleteNarrationFromDB(slideshowId: string): Promise<void> {
    const database = await initNarrationDB();
    return new Promise((resolve, reject) => {
      const tx = database.transaction(NARRATION_DB_STORE, 'readwrite');
      const store = tx.objectStore(NARRATION_DB_STORE);
      const request = store.delete(slideshowId);
      request.onsuccess = () => resolve();
      request.onerror = () => reject(request.error);
    });
  }

  // Make webcam bubble draggable
  function makeDraggable(el: HTMLElement) {
    let isDragging = false;
    let startX = 0, startY = 0;
    let origLeft = 0, origBottom = 0;

    el.addEventListener('mousedown', (e) => {
      isDragging = true;
      el.classList.add('dragging');
      startX = e.clientX;
      startY = e.clientY;
      const rect = el.getBoundingClientRect();
      origLeft = rect.left;
      origBottom = window.innerHeight - rect.bottom;
      e.preventDefault();
    });

    document.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      const dx = e.clientX - startX;
      const dy = e.clientY - startY;
      el.style.left = (origLeft + dx) + 'px';
      el.style.bottom = (origBottom - dy) + 'px';
    });

    document.addEventListener('mouseup', () => {
      isDragging = false;
      el.classList.remove('dragging');
    });
  }

  // Recording state
  let webcamStream: MediaStream | null = null;
  let recordingCanvas: HTMLCanvasElement | null = null;
  let recordingCtx: CanvasRenderingContext2D | null = null;
  let recordingAnimationId: number | null = null;
  let quoteCaptureInterval: number | null = null;

  // Start narration mode - captures slides + webcam overlay
  async function startNarrationMode() {
    const webcamBubble = document.getElementById('webcam-bubble');
    const webcamPreview = document.getElementById('webcam-preview') as HTMLVideoElement;
    const webcamControls = document.getElementById('webcam-controls');
    const webcamStart = document.getElementById('webcam-start');
    const initialRecordBtn = document.querySelector('.slideshow-record-btn') as HTMLElement;

    try {
      // Get webcam + audio
      webcamStream = await navigator.mediaDevices.getUserMedia({ video: true, audio: true });
      if (webcamPreview) webcamPreview.srcObject = webcamStream;
      if (webcamBubble) {
        webcamBubble.style.display = 'block';
        makeDraggable(webcamBubble);
      }
      if (webcamControls) webcamControls.style.display = 'flex';
      if (initialRecordBtn) initialRecordBtn.style.display = 'none';
      if (webcamStart) {
        webcamStart.textContent = '● Record';
        webcamStart.className = 'webcam-rec-btn start';
      }

      // Set up recording canvas (captures slideshow container + webcam overlay)
      recordingCanvas = document.createElement('canvas');
      recordingCanvas.width = 1920;
      recordingCanvas.height = 1080;
      recordingCtx = recordingCanvas.getContext('2d')!;

      // Create the combined stream for recording
      const canvasStream = recordingCanvas.captureStream(30);
      // Add audio track from webcam
      const audioTrack = webcamStream.getAudioTracks()[0];
      if (audioTrack) {
        canvasStream.addTrack(audioTrack);
      }
      narrationStream = canvasStream;

      // Start drawing frames
      startRecordingFrames();

    } catch (err) {
      alert('Could not access camera/microphone. Please allow access and try again.');
    }
  }

  // Store captured quote preview for recording
  let capturedQuoteCanvas: HTMLCanvasElement | null = null;
  let isCapturingQuote = false;

  // Capture the entire quote window (including title bar)
  async function captureQuotePreview() {
    if (isCapturingQuote || recordingSource !== 'quote') return;
    const windowEl = document.getElementById('quote-record-window');
    if (!windowEl) return;

    isCapturingQuote = true;
    try {
      // @ts-ignore - html2canvas loaded via script tag
      const canvas = await html2canvas(windowEl, {
        scale: 1.5,
        useCORS: true,
        logging: false,
        backgroundColor: null
      });
      capturedQuoteCanvas = canvas;
    } catch (err) {
      console.error('Failed to capture quote:', err);
    }
    isCapturingQuote = false;
  }

  // Continuously draw slideshow/quote + webcam to canvas
  function startRecordingFrames() {
    const webcamPreview = document.getElementById('webcam-preview') as HTMLVideoElement;

    // Start periodic capture for quotes
    if (recordingSource === 'quote') {
      captureQuotePreview(); // Initial capture
      quoteCaptureInterval = window.setInterval(captureQuotePreview, 200); // Capture every 200ms
    }

    function drawFrame() {
      if (!recordingCtx || !recordingCanvas) return;

      // Fill background
      recordingCtx.fillStyle = '#fafafa';
      recordingCtx.fillRect(0, 0, recordingCanvas.width, recordingCanvas.height);

      if (recordingSource === 'quote' && capturedQuoteCanvas) {
        // Draw brand background color
        recordingCtx.fillStyle = RECORDING_BRAND.bgColor;
        recordingCtx.fillRect(0, 0, recordingCanvas.width, recordingCanvas.height);

        // Draw captured window, scaled to fit with padding
        const srcW = capturedQuoteCanvas.width;
        const srcH = capturedQuoteCanvas.height;
        const canvasW = recordingCanvas.width;
        const canvasH = recordingCanvas.height;
        const padding = 60;

        // Scale to fit within padded area
        const maxW = canvasW - padding * 2;
        const maxH = canvasH - padding * 2;
        const scale = Math.min(maxW / srcW, maxH / srcH);
        const drawW = srcW * scale;
        const drawH = srcH * scale;
        const drawX = (canvasW - drawW) / 2;
        const drawY = (canvasH - drawH) / 2;

        recordingCtx.drawImage(capturedQuoteCanvas, 0, 0, srcW, srcH, drawX, drawY, drawW, drawH);

      } else if (currentSlideshow) {
        // Draw slideshow content
        const slide = currentSlideshow.slides[currentSlideIndex];
        const theme = slide?.theme || 'dark';

        // Draw slide background
        if (theme === 'gradient') {
          const gradient = recordingCtx.createLinearGradient(0, 0, recordingCanvas.width, recordingCanvas.height);
          gradient.addColorStop(0, '#00d4ff');
          gradient.addColorStop(0.5, '#7b2fff');
          gradient.addColorStop(1, '#ff006e');
          recordingCtx.fillStyle = gradient;
        } else if (theme === 'light' || theme === 'minimal') {
          recordingCtx.fillStyle = '#fafafa';
        } else if (theme === 'bold') {
          recordingCtx.fillStyle = '#000000';
        } else {
          recordingCtx.fillStyle = '#0a0a0f';
        }
        recordingCtx.fillRect(0, 0, recordingCanvas.width, recordingCanvas.height);

        // Draw headline
        if (slide?.headline) {
          recordingCtx.fillStyle = (theme === 'light' || theme === 'minimal') ? '#1a1a1a' : '#ffffff';
          recordingCtx.font = 'bold 72px Inter, sans-serif';
          recordingCtx.textAlign = 'center';
          recordingCtx.fillText(slide.headline, recordingCanvas.width / 2, recordingCanvas.height / 2 - 50);
        }

        // Draw bullets
        if (slide?.bullets && slide.bullets.length > 0) {
          recordingCtx.fillStyle = (theme === 'light' || theme === 'minimal') ? '#333333' : '#cccccc';
          recordingCtx.font = '36px Inter, sans-serif';
          recordingCtx.textAlign = 'center';
          slide.bullets.forEach((bullet, i) => {
            recordingCtx!.fillText('• ' + bullet, recordingCanvas!.width / 2, recordingCanvas!.height / 2 + 50 + (i * 50));
          });
        }
      }

      // Draw webcam bubble (bottom-right corner)
      if (webcamPreview && webcamPreview.readyState >= 2) {
        const bubbleSize = 200;
        const margin = 40;
        const x = recordingCanvas.width - bubbleSize - margin;
        const y = recordingCanvas.height - bubbleSize - margin;

        // Clip to circle
        recordingCtx.save();
        recordingCtx.beginPath();
        recordingCtx.arc(x + bubbleSize/2, y + bubbleSize/2, bubbleSize/2, 0, Math.PI * 2);
        recordingCtx.closePath();
        recordingCtx.clip();

        // Draw webcam (mirrored)
        recordingCtx.translate(x + bubbleSize, y);
        recordingCtx.scale(-1, 1);
        const vw = webcamPreview.videoWidth;
        const vh = webcamPreview.videoHeight;
        const size = Math.min(vw, vh);
        const sx = (vw - size) / 2;
        const sy = (vh - size) / 2;
        recordingCtx.drawImage(webcamPreview, sx, sy, size, size, 0, 0, bubbleSize, bubbleSize);
        recordingCtx.restore();

        // Draw cyan border
        recordingCtx.strokeStyle = '#00d4ff';
        recordingCtx.lineWidth = 6;
        recordingCtx.beginPath();
        recordingCtx.arc(x + bubbleSize/2, y + bubbleSize/2, bubbleSize/2, 0, Math.PI * 2);
        recordingCtx.stroke();
      }

      recordingAnimationId = requestAnimationFrame(drawFrame);
    }

    drawFrame();
  }

  // Start/stop recording
  function toggleNarrationRecording() {
    const webcamBubble = document.getElementById('webcam-bubble');
    const webcamStart = document.getElementById('webcam-start');

    if (!isNarrationRecording) {
      // Start recording
      if (!narrationStream) return;
      narrationChunks = [];
      narrationRecorder = new MediaRecorder(narrationStream);
      narrationRecorder.ondataavailable = (e) => {
        if (e.data.size > 0) narrationChunks.push(e.data);
      };
      narrationRecorder.onstop = saveNarration;
      narrationRecorder.start(500);
      isNarrationRecording = true;
      recordingStartTime = Date.now();
      webcamBubble?.classList.add('recording');

      // Start countdown timer
      recordingTimerInterval = window.setInterval(() => {
        if (!recordingStartTime) return;
        const elapsed = Math.floor((Date.now() - recordingStartTime) / 1000);
        const remaining = MAX_RECORDING_SECONDS - elapsed;

        if (remaining <= 0) {
          // Auto-stop at 10 minutes
          toggleNarrationRecording();
          showToast('Recording stopped - 10 minute limit reached');
        } else if (webcamStart) {
          const mins = Math.floor(remaining / 60);
          const secs = remaining % 60;
          webcamStart.textContent = `■ Stop (${mins}:${secs.toString().padStart(2, '0')})`;
        }
      }, 1000);

      if (webcamStart) {
        webcamStart.textContent = '■ Stop (10:00)';
        webcamStart.className = 'webcam-rec-btn stop';
      }
    } else {
      // Stop recording - show processing state
      if (recordingTimerInterval) {
        clearInterval(recordingTimerInterval);
        recordingTimerInterval = null;
      }
      recordingStartTime = null;
      webcamBubble?.classList.remove('recording');
      if (webcamStart) {
        webcamStart.textContent = 'Saving...';
        webcamStart.className = 'webcam-rec-btn save';
        webcamStart.setAttribute('disabled', 'true');
      }
      narrationRecorder?.stop();
      isNarrationRecording = false;
    }
  }

  // Save narration after recording stops (per-slide or per-quote)
  async function saveNarration() {
    const webcamBubble = document.getElementById('webcam-bubble');
    const webcamPreview = document.getElementById('webcam-preview') as HTMLVideoElement;
    const webcamStart = document.getElementById('webcam-start');

    // Validate we have recording data and source
    if (narrationChunks.length === 0) {
      alert('No recording data captured. Please record for at least 1 second.');
      closeNarrationMode();
      return;
    }

    if (recordingSource === 'slides' && !currentSlideshow) {
      closeNarrationMode();
      return;
    }

    if (recordingSource === 'quote' && !currentQuote) {
      closeNarrationMode();
      return;
    }

    const mimeType = narrationRecorder?.mimeType || 'video/webm';
    const blob = new Blob(narrationChunks, { type: mimeType });

    // Create a recording ID
    const recordingId = genId();

    try {
      // Save video blob to IndexedDB with recording ID as key (local backup)
      await saveNarrationToDB(recordingId, blob);

      // Capture thumbnail from current webcam frame
      let thumbnail = '';
      if (webcamPreview) {
        const canvas = document.createElement('canvas');
        canvas.width = 80;
        canvas.height = 80;
        const ctx = canvas.getContext('2d')!;
        ctx.translate(canvas.width, 0);
        ctx.scale(-1, 1);
        const size = Math.min(webcamPreview.videoWidth, webcamPreview.videoHeight);
        const sx = (webcamPreview.videoWidth - size) / 2;
        const sy = (webcamPreview.videoHeight - size) / 2;
        ctx.drawImage(webcamPreview, sx, sy, size, size, 0, 0, canvas.width, canvas.height);
        thumbnail = canvas.toDataURL('image/jpeg', 0.7);
      }

      // Upload to R2 for sharing
      if (webcamStart) {
        webcamStart.textContent = 'Uploading...';
      }
      const filename = `recording-${recordingId}.webm`;
      const cloudUrl = await uploadVideoToR2(filename, blob);

      // Create Recording entry based on source
      let recording: Recording;
      if (recordingSource === 'quote' && currentQuote) {
        recording = {
          id: recordingId,
          source: 'quote',
          sourceId: currentQuote.id,
          sourceTitle: currentQuote.title,
          thumbnail,
          cloudUrl: cloudUrl || undefined,
          createdAt: Date.now()
        };
      } else {
        const slide = currentSlideshow!.slides[currentSlideIndex];
        recording = {
          id: recordingId,
          source: 'slides',
          sourceId: currentSlideshow!.id,
          sourceTitle: currentSlideshow!.title,
          slideId: slide?.id,
          slideIndex: currentSlideIndex,
          thumbnail,
          cloudUrl: cloudUrl || undefined,
          createdAt: Date.now()
        };
      }

      recordings.unshift(recording);
      await saveRecordings();

      if (webcamStart) {
        webcamStart.textContent = '✓ Saved!';
        webcamStart.className = 'webcam-rec-btn save';
      }
      showToast(cloudUrl ? 'Recording saved & uploaded!' : 'Recording saved locally');

      setTimeout(() => {
        closeNarrationMode();
        // Navigate back to appropriate view
        if (recordingSource === 'quote') {
          view = 'editor';
          recordingSource = 'slides'; // reset for next time
        }
        render();
      }, 1500);
    } catch (err) {
      console.error('Failed to save narration:', err);
      alert('Failed to save narration');
      closeNarrationMode();
    }
  }

  // Close narration mode
  function closeNarrationMode() {
    const webcamBubble = document.getElementById('webcam-bubble');
    const webcamPreview = document.getElementById('webcam-preview') as HTMLVideoElement;
    const webcamControls = document.getElementById('webcam-controls');
    const initialRecordBtn = document.querySelector('.slideshow-record-btn') as HTMLElement;

    // Stop animation loop
    if (recordingAnimationId) {
      cancelAnimationFrame(recordingAnimationId);
      recordingAnimationId = null;
    }

    // Stop quote capture interval
    if (quoteCaptureInterval) {
      clearInterval(quoteCaptureInterval);
      quoteCaptureInterval = null;
    }
    capturedQuoteCanvas = null;

    // Stop webcam
    if (webcamStream) {
      webcamStream.getTracks().forEach(t => t.stop());
      webcamStream = null;
    }
    narrationStream = null;
    recordingCanvas = null;
    recordingCtx = null;

    if (webcamPreview) webcamPreview.srcObject = null;
    if (webcamBubble) webcamBubble.style.display = 'none';
    if (webcamControls) webcamControls.style.display = 'none';
    if (initialRecordBtn) initialRecordBtn.style.display = 'flex';
    isNarrationRecording = false;
    narrationChunks = [];
  }

  // Show narration playback for current slide
  async function showNarrationPlayback() {
    if (!currentSlideshow) return;
    const slide = currentSlideshow.slides[currentSlideIndex];
    if (!slide?.hasNarration) return;

    const playback = document.getElementById('narration-playback');
    const video = document.getElementById('narration-video') as HTMLVideoElement;

    try {
      const narrationKey = `${currentSlideshow.id}-${slide.id}`;
      const blob = await getNarrationFromDB(narrationKey);
      if (blob && playback && video) {
        // Apply saved position from slide
        if (slide.narrationPos) {
          playback.style.left = slide.narrationPos.left + 'px';
          playback.style.bottom = slide.narrationPos.bottom + 'px';
        }
        playback.style.display = 'block';
        video.src = URL.createObjectURL(blob);
        video.play();
        makeDraggable(playback);
      }
    } catch (e) {
      console.error('Failed to load narration:', e);
    }
  }

  // Hide narration playback
  function hideNarrationPlayback() {
    const playback = document.getElementById('narration-playback');
    const video = document.getElementById('narration-video') as HTMLVideoElement;
    if (playback) playback.style.display = 'none';
    if (video) {
      video.pause();
      video.src = '';
    }
  }

  // Restore recording state after render (called after attachListeners)
  function restoreWebcamState() {
    if (!webcamStream) return;

    const webcamBubble = document.getElementById('webcam-bubble');
    const webcamPreview = document.getElementById('webcam-preview') as HTMLVideoElement;
    const webcamControls = document.getElementById('webcam-controls');
    const webcamStart = document.getElementById('webcam-start');

    if (webcamPreview && webcamStream) {
      webcamPreview.srcObject = webcamStream;
    }
    if (webcamBubble) {
      webcamBubble.style.display = 'block';
      if (isNarrationRecording) {
        webcamBubble.classList.add('recording');
      }
      makeDraggable(webcamBubble);
    }
    if (webcamControls) {
      webcamControls.style.display = 'flex';
    }
    if (webcamStart) {
      if (isNarrationRecording) {
        webcamStart.textContent = '■ Stop & Save';
        webcamStart.className = 'webcam-rec-btn stop';
      } else {
        webcamStart.textContent = '● Record';
        webcamStart.className = 'webcam-rec-btn start';
      }
    }
  }

  // Delete narration from slideshow
  // Delete narration for current slide
  async function deleteNarration() {
    if (!currentSlideshow) return;
    const slide = currentSlideshow.slides[currentSlideIndex];
    if (!slide) return;
    if (!confirm('Delete the recorded narration for this slide?')) return;

    try {
      const narrationKey = `${currentSlideshow.id}-${slide.id}`;
      await deleteNarrationFromDB(narrationKey);
      slide.hasNarration = false;
      slide.narrationThumb = undefined;
      slide.narrationPos = undefined;
      currentSlideshow.updatedAt = Date.now();

      const idx = slideshows.findIndex(s => s.id === currentSlideshow!.id);
      if (idx >= 0) slideshows[idx] = currentSlideshow;
      await saveSlideshows();

      showToast('Narration deleted');
      render();
    } catch (err) {
      console.error('Failed to delete narration:', err);
    }
  }

  function showToast(msg: string) {
    toastMessage = msg;
    render();
    setTimeout(() => { toastMessage = ''; render(); }, 3000);
  }

  function createFromTemplate(template: Template) {
    const now = Date.now();
    currentQuote = {
      id: genId(),
      title: template.name === 'Blank Quote' ? 'Untitled Quote' : template.name,
      clientName: '',
      clientEmail: '',
      status: 'draft',
      createdAt: now,
      updatedAt: now,
      viewCount: 0,
      blocks: JSON.parse(JSON.stringify(template.blocks)),
      total: 0,
      currency: 'NZD'
    };
    currentQuote.total = calcTotal(currentQuote.blocks);
    view = 'editor';
    render();
  }

  async function saveCurrentQuote() {
    if (!currentQuote || saving) return;
    saving = true;
    render();

    try {
      currentQuote.updatedAt = Date.now();
      currentQuote.total = calcTotal(currentQuote.blocks);

      const idx = quotes.findIndex(q => q.id === currentQuote!.id);
      if (idx >= 0) {
        quotes[idx] = currentQuote;
      } else {
        quotes.unshift(currentQuote);
      }
      await saveQuotes();
      showToast('Quote saved!');
    } catch (err) {
      console.error('Save failed:', err);
      showToast('Save failed');
    } finally {
      saving = false;
      render();
    }
  }

  async function sendQuote() {
    if (!currentQuote || sending) return;
    if (!currentQuote.clientEmail) {
      alert('Please add a client email address');
      return;
    }

    // Save first
    await saveCurrentQuote();

    // Build mailto link
    const quoteUrl = `${window.location.origin}/view?id=${currentQuote.id}`;
    const subject = `Your Proposal: ${currentQuote.title}`;
    const body = `Hi ${currentQuote.clientName || 'there'},

Thank you for your interest in working with Bridge Point. I've prepared a proposal for you.

Proposal Total: ${formatCurrency(currentQuote.total, currentQuote.currency)}

View your proposal here:
${quoteUrl}

If you have any questions, feel free to reply to this email.

Best regards,
Ben Wilson
Bridge Point`;

    const mailtoUrl = `mailto:${currentQuote.clientEmail}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    window.open(mailtoUrl, '_blank');

    // Update status
    currentQuote.status = 'sent';
    const idx = quotes.findIndex(q => q.id === currentQuote!.id);
    if (idx >= 0) quotes[idx] = currentQuote;
    await saveQuotes();

    showToast('Email draft opened!');
    showModal = false;
    render();
  }

  async function deleteQuote(id: string) {
    if (!confirm('Delete this quote?')) return;
    quotes = quotes.filter(q => q.id !== id);
    await saveQuotes();
    render();
  }

  function addBlock(type: Block['type']) {
    if (!currentQuote) return;
    const id = genId();
    let block: Block;

    switch (type) {
      case 'hero':
        block = { id, type: 'hero', title: 'Your Title', subtitle: 'Subtitle here' };
        break;
      case 'section':
        block = { id, type: 'section', title: 'Section Title', content: 'Your content here...' };
        break;
      case 'pricing':
        block = { id, type: 'pricing', title: 'Investment', showTotal: true, items: [
          { id: genId(), name: 'Item', description: 'Description', quantity: 1, unitPrice: 0, optional: false, selected: true }
        ]};
        break;
      case 'divider':
        block = { id, type: 'divider' };
        break;
      case 'accept':
        block = { id, type: 'accept', buttonText: 'Accept Proposal', terms: 'By accepting, you agree to the terms.' };
        break;
      case 'split':
        block = { id, type: 'split', title: 'Section Title', content: 'Add your content here...', imageUrl: '' };
        break;
      default:
        return;
    }

    currentQuote.blocks.push(block);
    render();
  }

  function removeBlock(id: string) {
    if (!currentQuote) return;
    currentQuote.blocks = currentQuote.blocks.filter(b => b.id !== id);
    render();
  }

  function moveBlock(id: string, dir: -1 | 1) {
    if (!currentQuote) return;
    const idx = currentQuote.blocks.findIndex(b => b.id === id);
    if (idx < 0) return;
    const newIdx = idx + dir;
    if (newIdx < 0 || newIdx >= currentQuote.blocks.length) return;
    const blocks = [...currentQuote.blocks];
    [blocks[idx], blocks[newIdx]] = [blocks[newIdx], blocks[idx]];
    currentQuote.blocks = blocks;
    render();
  }

  function editPricing(blockId: string) {
    if (!currentQuote) return;
    const block = currentQuote.blocks.find(b => b.id === blockId) as PricingBlock | undefined;
    if (block) {
      editingPricingBlock = JSON.parse(JSON.stringify(block));
      modalType = 'pricing';
      showModal = true;
      render();
    }
  }

  function savePricingEdit() {
    if (!currentQuote || !editingPricingBlock) return;
    const idx = currentQuote.blocks.findIndex(b => b.id === editingPricingBlock!.id);
    if (idx >= 0) {
      currentQuote.blocks[idx] = editingPricingBlock;
    }
    showModal = false;
    editingPricingBlock = null;
    render();
  }

