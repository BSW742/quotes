---
// Client quote view page
// Access via /view?id=QUOTE_ID
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quote - Bridge Point</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
</head>
<body>
  <div id="app"></div>
</body>
</html>

<style is:global>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --bg: #fafafa;
    --bg-card: #ffffff;
    --bg-hover: #f5f5f7;
    --border: #e5e5e5;
    --text: #1a1a1a;
    --text-muted: #666666;
    --cyan: #00d4ff;
    --purple: #7b2fff;
    --pink: #ff006e;
    --gradient: linear-gradient(135deg, var(--cyan), var(--purple), var(--pink));
  }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }

  /* Website backdrop */
  .website-backdrop {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    opacity: 0.12;
  }

  .website-backdrop iframe {
    width: 100%;
    height: 100%;
    border: none;
    pointer-events: none;
  }

  .quote-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .quote-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 40px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
  }

  .logo {
    height: 32px;
    
  }

  .quote-meta {
    text-align: right;
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .quote-content {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  /* Hero Block - Default gradient style */
  .block-hero {
    padding: 60px 40px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    background: var(--gradient);
    color: white;
  }

  /* Hero themes */
  .block-hero.theme-cyan { background: linear-gradient(135deg, #00d4ff, #0099cc); }
  .block-hero.theme-purple { background: linear-gradient(135deg, #7b2fff, #5a1fcc); }
  .block-hero.theme-blue { background: linear-gradient(135deg, #0066ff, #0044cc); }
  .block-hero.theme-dark { background: linear-gradient(135deg, #1a1a2e, #16213e); }
  .block-hero.theme-light {
    background: linear-gradient(135deg, #f8f9fa, #e9ecef);
    color: var(--text);
  }
  .block-hero.theme-light .hero-title {
    color: var(--purple);
  }
  .block-hero.theme-light .hero-subtitle { color: var(--text-muted); }
  .block-hero.theme-light .hero-meta { border-top-color: var(--border); }

  /* Light mode hero for dark logos */
  .block-hero.light-mode {
    background: linear-gradient(180deg, #ffffff 0%, #f8f9fa 100%);
    color: var(--text);
  }

  .block-hero.light-mode .hero-title {
    color: var(--purple);
  }

  .block-hero.light-mode .hero-subtitle {
    color: var(--text-muted);
  }

  .client-logo-section {
    margin-bottom: 40px;
  }

  .client-logo {
    max-height: 80px;
    max-width: 280px;
    object-fit: contain;
  }

  .hero-divider {
    width: 60px;
    height: 3px;
    background: rgba(255,255,255,0.4);
    margin: 30px auto;
    border-radius: 2px;
  }

  .block-hero.light-mode .hero-divider {
    background: var(--purple);
  }

  .hero-title {
    font-size: 2.4rem;
    font-weight: 800;
    margin-bottom: 16px;
    line-height: 1.2;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    opacity: 0.9;
    max-width: 500px;
    margin: 0 auto;
  }

  .hero-meta {
    margin-top: 30px;
    padding-top: 30px;
    border-top: 1px solid rgba(255,255,255,0.2);
    display: flex;
    justify-content: center;
    gap: 40px;
    font-size: 0.9rem;
  }

  .block-hero.light-mode .hero-meta {
    border-top-color: var(--border);
  }

  .hero-meta-item {
    text-align: center;
  }

  .hero-meta-item .label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    opacity: 0.7;
    margin-bottom: 4px;
  }

  .hero-meta-item .value {
    font-weight: 600;
  }

  /* Section Block */
  .block-section {
    padding: 40px;
    border-bottom: 1px solid var(--border);
  }

  .block-section:last-of-type {
    border-bottom: none;
  }

  .block-section h2 {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: var(--text);
  }

  .block-section p {
    line-height: 1.8;
    color: var(--text);
    white-space: pre-line;
  }

  /* Text Block */
  .block-text {
    padding: 30px 40px;
  }

  .block-text p {
    line-height: 1.7;
    color: var(--text);
  }

  /* Split Block */
  .block-split {
    display: flex;
    gap: 40px;
    padding: 40px;
    align-items: center;
  }

  .split-content {
    flex: 1;
  }

  .split-content h2 {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: var(--purple);
  }

  .split-content p {
    line-height: 1.8;
    color: var(--text);
    white-space: pre-line;
  }

  .split-image {
    flex: 1;
  }

  .split-image img {
    width: 100%;
    border-radius: 12px;
  }


  /* Pricing Block */
  .block-pricing {
    padding: 40px;
    background: var(--bg-hover);
  }

  .block-pricing h3 {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 24px;
    color: var(--text);
  }

  .pricing-table {
    width: 100%;
    border-collapse: collapse;
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .pricing-table th {
    text-align: left;
    padding: 14px 16px;
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    background: var(--bg-card);
    border-bottom: 1px solid var(--border);
  }

  .pricing-table td {
    padding: 18px 16px;
    border-bottom: 1px solid var(--border);
  }

  .pricing-table tr:last-child td {
    border-bottom: none;
  }

  .pricing-table .item-name {
    font-weight: 600;
    color: var(--text);
  }

  .pricing-table .item-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 4px;
  }

  .pricing-table .item-price {
    text-align: right;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: var(--text);
  }

  .item-optional {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .item-checkbox {
    width: 22px;
    height: 22px;
    accent-color: var(--purple);
    cursor: pointer;
  }

  .pricing-total {
    display: flex;
    justify-content: space-between;
    padding: 24px 16px;
    font-size: 1.4rem;
    font-weight: 700;
    background: white;
    border-radius: 12px;
    margin-top: 16px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .pricing-total .amount {
    color: var(--text);
  }

  /* Divider */
  .block-divider {
    padding: 20px 40px;
  }

  .block-divider hr {
    border: none;
    height: 1px;
    background: var(--border);
  }

  /* Accept Block */
  .block-accept {
    padding: 60px 40px;
    text-align: center;
    background: linear-gradient(180deg, var(--bg-hover) 0%, var(--bg-card) 100%);
    border-top: 1px solid var(--border);
  }

  .block-accept .terms {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 30px;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
  }

  .signature-area {
    margin-bottom: 30px;
  }

  .signature-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 10px;
  }

  .signature-input {
    width: 100%;
    max-width: 320px;
    padding: 14px 18px;
    background: white;
    border: 2px solid var(--border);
    border-radius: 10px;
    color: var(--text);
    font-size: 1.1rem;
    text-align: center;
    font-weight: 500;
  }

  .signature-input:focus {
    outline: none;
    border-color: var(--purple);
    box-shadow: 0 0 0 3px rgba(123, 47, 255, 0.1);
  }

  .accept-btn {
    padding: 18px 60px;
    font-size: 1.1rem;
    font-weight: 700;
    background: var(--gradient);
    border: none;
    border-radius: 12px;
    color: white;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 4px 15px rgba(123, 47, 255, 0.25);
  }

  .accept-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(123, 47, 255, 0.35);
  }

  .accept-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  /* Accepted State */
  .accepted-banner {
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.1), rgba(34, 197, 94, 0.05));
    border: 1px solid rgba(34, 197, 94, 0.25);
    padding: 24px;
    border-radius: 16px;
    text-align: center;
    margin-top: 30px;
  }

  .accepted-banner h3 {
    color: #16a34a;
    font-size: 1.3rem;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .accepted-banner h3::before {
    content: '✓';
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background: #16a34a;
    color: white;
    border-radius: 50%;
    font-size: 0.9rem;
  }

  .accepted-banner p {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  /* Loading / Error States */
  .loading, .error {
    text-align: center;
    padding: 100px 20px;
  }

  .loading {
    color: var(--text-muted);
  }

  .error h2 {
    font-size: 1.4rem;
    margin-bottom: 12px;
    color: var(--text);
  }

  .error p {
    color: var(--text-muted);
  }

  /* Footer */
  .quote-footer {
    text-align: center;
    padding: 50px 20px;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .quote-footer a {
    color: var(--purple);
    text-decoration: none;
    font-weight: 600;
  }

  /* Print signature box - hidden on screen, shown in PDF */
  .print-signature-box {
    display: none;
    margin-top: 40px;
    padding: 30px;
    border: 2px solid var(--border);
    border-radius: 12px;
    background: white;
  }
  .print-signature-box h4 {
    font-size: 1rem;
    margin-bottom: 24px;
    color: var(--text);
  }
  .signature-line {
    display: flex;
    gap: 40px;
    margin-bottom: 20px;
  }
  .signature-field {
    flex: 1;
  }
  .signature-field label {
    display: block;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .signature-field .line {
    border-bottom: 1px solid #333;
    height: 40px;
  }

  /* PDF mode - clean view */
  body.pdf-mode .website-backdrop { display: none !important; }
  body.pdf-mode .quote-footer { display: none !important; }
  body.pdf-mode .quote-page { padding: 20px; max-width: none; }
  body.pdf-mode .quote-header { margin-bottom: 20px; }
  body.pdf-mode .quote-content { box-shadow: none; border: 1px solid #ddd; }
  body.pdf-mode .block-section { padding: 24px 30px; }\n  body.pdf-mode .block-split { padding: 24px 30px; }
  body.pdf-mode .block-pricing { padding: 24px 30px; }
  body.pdf-mode .block-hero { padding: 30px; }
  body.pdf-mode .client-logo-section { margin-bottom: 20px; }
  body.pdf-mode .hero-meta { margin-top: 20px; padding-top: 20px; }
  body.pdf-mode .accept-btn { display: none; }
  body.pdf-mode .signature-area { display: none; }
  body.pdf-mode .signature-input { display: none; }
  body.pdf-mode .print-signature-box { display: block; }
  body.pdf-mode .accepted-banner { display: none; }
  body.pdf-mode .block-accept .terms { margin-bottom: 0; }

  /* Print styles */
  @media print {
    body { background: white; }
    .website-backdrop { display: none !important; }
    .quote-page { padding: 20px; max-width: none; }
    .quote-header { margin-bottom: 20px; }
    .quote-content { box-shadow: none; border: 1px solid #ddd; }
    .quote-footer { display: none; }
    .block-hero { padding: 40px 30px; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .block-section { padding: 24px 30px; }
    .block-pricing { padding: 24px 30px; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .block-accept { padding: 30px; }
    .accept-btn { display: none; }
    .signature-area { display: none; }
    .signature-input { display: none; }
    .print-signature-box { display: block; }
    .accepted-banner { display: none; }
  }
</style>

<script>
  import type { Quote, Block, PricingBlock, SectionBlock, HeroTheme } from '../lib/types';
  import { saveToR2, WORKER_URL } from '../lib/r2';

  let quote: Quote | null = null;
  let allQuotes: Quote[] = [];
  let loading = true;
  let error = '';
  let signature = '';
  let accepting = false;

  // Get quote ID from URL params
  const params = new URLSearchParams(window.location.search);
  const quoteId = params.get('id');

  function formatCurrency(amount: number, currency = 'NZD'): string {
    return new Intl.NumberFormat('en-NZ', { style: 'currency', currency }).format(amount);
  }

  function formatDate(ts: number): string {
    return new Date(ts).toLocaleDateString('en-NZ', { day: 'numeric', month: 'long', year: 'numeric' });
  }

  function calcTotal(): number {
    if (!quote) return 0;
    let total = 0;
    quote.blocks.forEach(b => {
      if (b.type === 'pricing') {
        b.items.forEach(item => {
          if (item.selected) {
            total += item.quantity * item.unitPrice;
          }
        });
      }
    });
    return total;
  }

  async function loadQuote() {
    if (!quoteId) {
      error = 'No quote ID provided';
      loading = false;
      render();
      return;
    }

    try {
      const response = await fetch(`${WORKER_URL}?file=quotes-data.json&t=${Date.now()}`);
      if (!response.ok) {
        error = 'Quote not found';
        loading = false;
        render();
        return;
      }

      const data = await response.json();
      allQuotes = data.quotes || [];
      quote = allQuotes.find((q: Quote) => q.id === quoteId) || null;

      if (!quote) {
        error = 'Quote not found';
      } else {
        // Track view
        quote.viewCount++;
        if (quote.status === 'sent') {
          quote.status = 'viewed';
        }
        // Save updated view count
        const idx = allQuotes.findIndex((q: Quote) => q.id === quoteId);
        if (idx >= 0) {
          allQuotes[idx] = quote;
          await saveToR2('quotes-data.json', { quotes: allQuotes });
        }
      }
    } catch (e) {
      error = 'Failed to load quote';
    }

    loading = false;
    render();
  }

  async function acceptQuote() {
    if (!quote || !signature.trim() || accepting) return;

    accepting = true;
    render();

    try {
      const idx = allQuotes.findIndex((q: Quote) => q.id === quoteId);
      if (idx >= 0) {
        allQuotes[idx].status = 'accepted';
        allQuotes[idx].acceptedAt = Date.now();
        allQuotes[idx].signature = signature;
        allQuotes[idx].total = calcTotal();
        quote = allQuotes[idx];
        await saveToR2('quotes-data.json', { quotes: allQuotes });
      }
    } catch (e) {
      alert('Failed to accept quote. Please try again.');
    }

    accepting = false;
    render();
  }

  function toggleOptionalItem(blockId: string, itemId: string) {
    if (!quote) return;
    const block = quote.blocks.find(b => b.id === blockId) as PricingBlock | undefined;
    if (!block) return;
    const item = block.items.find(i => i.id === itemId);
    if (item && item.optional) {
      item.selected = !item.selected;
      render();
    }
  }

  function render() {
    const app = document.getElementById('app');
    if (!app) return;

    if (loading) {
      app.innerHTML = `<div class="loading"><p>Loading quote...</p></div>`;
      return;
    }

    if (error || !quote) {
      app.innerHTML = `
        <div class="error">
          <h2>Quote Not Found</h2>
          <p>This quote may have expired or been removed.</p>
        </div>
      `;
      return;
    }

    // Get website URL for backdrop
    let websiteUrl = '';
    if (quote.clientWebsite) {
      websiteUrl = quote.clientWebsite.trim();
      if (!websiteUrl.startsWith('http://') && !websiteUrl.startsWith('https://')) {
        websiteUrl = 'https://' + websiteUrl;
      }
    }

    app.innerHTML = `
      ${websiteUrl ? `
        <div class="website-backdrop">
          <iframe src="${websiteUrl}" sandbox="allow-same-origin allow-scripts" loading="lazy"></iframe>
        </div>
      ` : ''}

      <div class="quote-page">
        ${quote.showHeader !== false ? `<header class="quote-header">
          <img src="data:image/png;base64," alt="Bridge Point" class="logo">
          <div class="quote-meta">
            <div>Quote for ${quote.clientName || 'You'}</div>
            <div>${formatDate(quote.createdAt)}</div>
          </div>
        </header>` : ''}

        <div class="quote-content">
          ${quote.blocks.map(b => renderBlock(b)).join('')}
        </div>

        ${quote.status === 'accepted' ? `
          <div class="accepted-banner">
            <h3>Quote Accepted</h3>
            <p>Signed by ${quote.signature} on ${formatDate(quote.acceptedAt!)}</p>
          </div>
        ` : ''}

        <footer class="quote-footer">
          <p>Powered by <a href="https://bridgepoint.co.nz" target="_blank">Bridge Point</a></p>
        </footer>
      </div>
    `;

    attachListeners();
  }

  function renderBlock(block: Block): string {
    switch (block.type) {
      case 'hero':
        const themeClass = quote?.heroTheme && quote.heroTheme !== 'gradient' ? `theme-${quote.heroTheme}` : '';
        const hasLogo = !!quote?.clientLogo;

        // Replace placeholder in subtitle
        const subtitle = block.subtitle.replace('[Client Name]', quote?.clientName || 'You');

        return `
          <div class="block-hero ${themeClass}">
            ${hasLogo ? `
              <div class="client-logo-section">
                <img
                  src="${quote!.clientLogo}"
                  alt="${quote?.clientName || ''}"
                  class="client-logo"
                >
              </div>
            ` : ''}
            <h1 class="hero-title">${block.title}</h1>
            <p class="hero-subtitle">${subtitle}</p>
            <div class="hero-meta">
              <div class="hero-meta-item">
                <div class="label">Prepared For</div>
                <div class="value">${quote?.clientName || 'You'}</div>
              </div>
              <div class="hero-meta-item">
                <div class="label">Date</div>
                <div class="value">${formatDate(quote?.createdAt || Date.now())}</div>
              </div>
              <div class="hero-meta-item">
                <div class="label">Valid Until</div>
                <div class="value">${formatDate((quote?.createdAt || Date.now()) + 30 * 24 * 60 * 60 * 1000)}</div>
              </div>
            </div>
          </div>
        `;

      case 'section':
        return `
          <div class="block-section">
            <h2>${block.title}</h2>
            <p>${block.content}</p>
          </div>
        `;

      case 'text':
        return `
          <div class="block-text">
            <p>${block.content}</p>
          </div>
        `;

      case 'pricing':
        const total = block.items.reduce((sum, i) => i.selected ? sum + (Number(i.quantity) * Number(i.unitPrice)) : sum, 0);
        return `
          <div class="block-pricing">
            <h3>${block.title}</h3>
            <table class="pricing-table">
              <thead>
                <tr>
                  <th>Item</th>
                  <th style="text-align:right">Unit Price</th>
                  <th style="text-align:center">Qty</th>
                  <th style="text-align:right">Total</th>
                </tr>
              </thead>
              <tbody>
                ${block.items.map(item => `
                  <tr style="${!item.selected ? 'opacity:0.4' : ''}">
                    <td>
                      <div class="item-optional">
                        ${item.optional && quote?.status !== 'accepted' ? `
                          <input type="checkbox" class="item-checkbox"
                            data-block="${block.id}" data-item="${item.id}"
                            ${item.selected ? 'checked' : ''}>
                        ` : ''}
                        <div>
                          <div class="item-name">${item.name}${item.optional ? ' (Optional)' : ''}</div>
                          <div class="item-desc">${item.description}</div>
                        </div>
                      </div>
                    </td>
                    <td style="text-align:right">${formatCurrency(item.unitPrice)}</td>
                    <td style="text-align:center">${item.quantity}</td>
                    <td class="item-price" style="text-align:right">${formatCurrency(Number(item.quantity) * Number(item.unitPrice))}</td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
            ${block.showTotal ? `
              <div class="pricing-total">
                <span>Total</span>
                <span class="amount">${formatCurrency(total)}</span>
              </div>
            ` : ''}
          </div>
        `;

      case 'divider':
        return `<div class="block-divider"><hr></div>`;

      case 'split':
        return `
          <div class="block-split">
            <div class="split-content">
              <h2>${block.title}</h2>
              <p>${block.content}</p>
            </div>
            <div class="split-image">
              ${block.imageUrl ? `<img src="${block.imageUrl}" alt="">` : ''}
            </div>
          </div>
        `;

      case 'accept':
        if (quote?.status === 'accepted') {
          return `
            <div class="block-accept">
              <p class="terms">This quote has been accepted.</p>
            </div>
          `;
        }
        return `
          <div class="block-accept">
            <p class="terms">${block.terms}</p>
            <div class="signature-area">
              <div class="signature-label">Type your name to sign</div>
              <input type="text" class="signature-input" id="signature" placeholder="Your Name" value="${signature}">
            </div>
            <button class="accept-btn" id="accept-btn" ${!signature.trim() || accepting ? 'disabled' : ''}>
              ${accepting ? 'Accepting...' : block.buttonText}
            </button>
            <div class="print-signature-box">
              <h4>Acceptance & Signature</h4>
              <div class="signature-line">
                <div class="signature-field">
                  <label>Signature</label>
                  <div class="line"></div>
                </div>
                <div class="signature-field">
                  <label>Date</label>
                  <div class="line"></div>
                </div>
              </div>
              <div class="signature-line">
                <div class="signature-field">
                  <label>Print Name</label>
                  <div class="line"></div>
                </div>
                <div class="signature-field">
                  <label>Position / Title</label>
                  <div class="line"></div>
                </div>
              </div>
            </div>
          </div>
        `;

      default:
        return '';
    }
  }

  function attachListeners() {
    // Signature input
    document.getElementById('signature')?.addEventListener('input', (e) => {
      signature = (e.target as HTMLInputElement).value;
      const btn = document.getElementById('accept-btn') as HTMLButtonElement;
      if (btn) {
        btn.disabled = !signature.trim() || accepting;
      }
    });

    // Accept button
    document.getElementById('accept-btn')?.addEventListener('click', acceptQuote);

    // Optional item toggles
    document.querySelectorAll('.item-checkbox').forEach(checkbox => {
      checkbox.addEventListener('change', () => {
        const el = checkbox as HTMLInputElement;
        const blockId = el.dataset.block!;
        const itemId = el.dataset.item!;
        toggleOptionalItem(blockId, itemId);
      });
    });
  }

  // Init
  loadQuote().then(async () => {
    // Auto-generate PDF if ?print=1
    if (params.get('print') === '1' && quote) {
      // Wait for page to fully render
      await new Promise(r => setTimeout(r, 800));

      document.body.classList.add('pdf-mode');

      // Wait for all images to load before PDF capture
      const images = document.querySelectorAll('img');
      await Promise.all(Array.from(images).map(img => {
        if (img.complete && img.naturalHeight > 0) return Promise.resolve();
        return new Promise(resolve => {
          img.onload = resolve;
          img.onerror = resolve;
        });
      }));

      const element = document.querySelector('.quote-page');
      const filename = `${quote.title.replace(/[^a-z0-9]/gi, '-')}-proposal.pdf`;

      const opt = {
        margin: [10, 10, 10, 10],
        filename: filename,
        image: { type: 'jpeg', quality: 0.95 },
        html2canvas: { scale: 2, useCORS: true, allowTaint: true, logging: false },
        jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' },
        pagebreak: { mode: 'avoid-all' }
      };

      (window as any).html2pdf().set(opt).from(element).save().then(() => {
        setTimeout(() => window.close(), 1000);
      });
    }
  });
</script>
